---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products.js';

const appCount = products.filter((p) => p.type === 'app').length;
const webCount = products.filter((p) => p.type === 'web').length;
const cats = [
  { label: '교육', cls: '', items: products.filter((p) => p.section === 'edu') },
  { label: '일상', cls: ' daily', items: products.filter((p) => p.section === 'daily') },
];
---

<Layout
  title="제품 — 로직크래프트 LogicCraft"
  description="로직크래프트가 기획·디자인·출시까지 직접 만든 사고력 시리즈와 일상 도구들."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="page-hero">
    <canvas class="hero-net" aria-hidden="true"></canvas>
    <div class="wrap">
      <p class="eyebrow on-dark">PRODUCTS · 전체 제품</p>
      <h1>{appCount}개의 앱, {webCount}개의 웹</h1>
      <p class="lead">사고력을 기르는 앱부터, 매일 쓰는 도구까지.</p>
    </div>
  </section>

  <!-- ============ SYNERGEION SERIES ============ -->
  <section class="section">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">SYNERGEION · 우리가 만드는 학교</p>
        <h2 class="section-title">3세부터 18세까지, 하나의 학교.</h2>
        <p class="section-lead">συνεργεῖον — “함께 일하고 성취하는 장소”. 배움의 다섯 단계가 하나의 학교로 이어집니다.</p>
        <div class="pullquote" style="margin: 18px 0 0; max-width: 72ch">
          <p><strong>분해하고 조립하면서 사고력과 문제해결력을 길러 줍니다.</strong></p>
        </div>
      </div>
      <div class="journey reveal" style="margin-top: clamp(36px,5vw,56px); max-width: 880px">
        <div class="spine"><div class="spine-fill" id="spineFill"></div></div>
        <div class="stage" style="--st: var(--st-wonder)">
          <span class="num">01</span>
          <div class="body"><h4>Wonder <span class="age">3–6세</span></h4><p>씨앗을 심고 매일 자라는 걸 지켜봅니다. 세상의 작은 것들이 궁금해지는 때입니다. <a href="/apps/wonder/" style="color:var(--blue);font-weight:700;white-space:nowrap">자세히 →</a> <a href="https://apps.apple.com/kr/app/id6774041352" style="color:var(--blue);font-weight:700;white-space:nowrap">App Store ↗</a> <a href="https://play.google.com/store/apps/details?id=kr.logiccraft.wonder" style="color:var(--blue);font-weight:700;white-space:nowrap">Google Play ↗</a></p></div>
          <span class="tag live">출시</span>
        </div>
        <div class="stage" style="--st: var(--st-build)">
          <span class="num">02</span>
          <div class="body"><h4>Build <span class="age">6–9세</span></h4><p>자란 나무로 집과 배를 만듭니다. 직접 손으로 만들고 부수며 원리를 익힙니다. <a href="/apps/build/" style="color:var(--blue);font-weight:700;white-space:nowrap">자세히 →</a> <a href="https://apps.apple.com/kr/app/id6777975502" style="color:var(--blue);font-weight:700;white-space:nowrap">App Store ↗</a> <a href="https://play.google.com/store/apps/details?id=kr.logiccraft.build" style="color:var(--blue);font-weight:700;white-space:nowrap">Google Play ↗</a></p></div>
          <span class="tag live">출시</span>
        </div>
        <div class="stage" style="--st: var(--st-voyage)">
          <span class="num">03</span>
          <div class="body"><h4>Voyage <span class="age">9–12세</span></h4><p>배를 타고 새 땅을 찾아 나섭니다. 궁금한 것을 직접 조사하고 자기 말로 설명합니다.</p></div>
          <span class="tag soon">예정</span>
        </div>
        <div class="stage" style="--st: var(--st-forge)">
          <span class="num">04</span>
          <div class="body"><h4>Forge <span class="age">12–15세</span></h4><p>내가 만든 도구로 자기만의 집을 짓습니다. 자신만의 생각하는 방식을 갖추는 단계입니다.</p></div>
          <span class="tag soon">예정</span>
        </div>
        <div class="stage" style="--st: var(--st-village)">
          <span class="num">05</span>
          <div class="body"><h4>Village <span class="age">15–18세</span></h4><p>사람들과 함께 마을을 이룹니다. 관계 속에서 자기 역할과 갈 길을 찾습니다.</p></div>
          <span class="tag soon">예정</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MASCOTS ============ -->
  <section class="section tint">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow warm">MASCOTS · 마스코트</p>
        <h2 class="section-title">나루와 느티.</h2>
      </div>
      <div class="mascot-bios" style="margin-top: clamp(32px,4vw,48px)">
        <div class="bio reveal">
          <img src="/mascots/naru.png" alt="나루" />
          <div class="who">
            <span class="nm"><b>나루</b><span>NARU</span></span>
            <p class="role">아기 비버 · 만드는 손</p>
            <p>배에 물음표를 안고 다니는 호기심 많은 아기 비버.</p>
          </div>
        </div>
        <div class="bio reveal">
          <img src="/mascots/neti.png" alt="느티" />
          <div class="who">
            <span class="nm"><b>느티</b><span>NETI</span></span>
            <p class="role">새싹 정령 · 자라남</p>
            <p>막 흙을 밀고 올라온 새싹 정령. 날마다 조금씩 자라며, 아이와 함께 크는 마음을 담았습니다.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STUDIO PRODUCTS ============ -->
  <section class="products">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">STUDIO · 일상 제품</p>
      </div>

      {cats.map((c, ci) => (
        <div class="section-block" style={ci === 0 ? 'margin-top: clamp(32px,4vw,52px)' : ''}>
          <div class={`cat-head reveal${c.cls}`}>
            <span class="label">{c.label}</span>
            <span class="rule"></span>
            <span class="count">{String(c.items.length).padStart(2, '0')}</span>
          </div>
          <div class="card-grid">
            {c.items.map((p) => <ProductCard p={p} />)}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

