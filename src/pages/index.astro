---
import Layout from '../layouts/Layout.astro';
import Hero3D from '../components/Hero3D.astro';
import AppCard from '../components/AppCard.astro';
import { apps, categories } from '../data/apps';
import { series } from '../data/synergeion';

const live = apps.filter((a) => a.status === 'live');
const soon = apps.filter((a) => a.status === 'soon');
const BOOK_URL = 'https://product.kyobobook.co.kr/detail/S000219252300';
const YT_URL = 'https://www.youtube.com/@logiccraftmovie';
---

<Layout>
  <Hero3D>
    <p class="eyebrow" style="color: var(--accent-soft);">LOGICCRAFT</p>
    <h1>생각하는 힘을 키우는<br />제품을 만듭니다.</h1>
    <p class="lede">
      로직크래프트는 사고력·판단력을 기르는 앱과 학습 플랫폼을 만듭니다.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href="#products">제품 보기</a>
      <a class="btn btn-ghost ghost-dark" href="/about">스튜디오 소개</a>
    </div>
  </Hero3D>

  <!-- Synergeion 피처 -->
  <section id="series" class="syn-feature">
    <div class="wrap">
      <p class="brandline">SYNERGEION</p>
      <div class="syn-top">
        <div class="syn-copy">
          <h2>3세부터 18세까지,<br />하나의 여정으로 이어집니다.</h2>
          <p class="vision">“{series.vision}”</p>
          <p class="value">{series.value}</p>
          <a class="btn btn-accent syn-cta" href="/synergeion">시리즈 자세히 보기 →</a>
        </div>
        <div class="mascots">
          <figure class="mascot">
            <img src="/mascots/naru.png" alt="나루 — 아기 비버 마스코트" width="150" loading="lazy" />
            <figcaption>나루 <span>NARU</span></figcaption>
          </figure>
          <figure class="mascot">
            <img src="/mascots/neti.png" alt="느티 — 새싹 정령 마스코트" width="150" loading="lazy" />
            <figcaption>느티 <span>NETI</span></figcaption>
          </figure>
        </div>
      </div>

    </div>
  </section>

  <section id="products" class="wrap">
    <div class="section-head">
      <p class="eyebrow">스튜디오 제품</p>
      <p class="sub">시리즈와 별개로, 작고 또렷한 목적을 가진 도구들.</p>
    </div>
    {categories.map((cat) => {
      const items = live.filter((a) => a.category === cat);
      const seriesItems = items.filter((a) => a.series);
      const studioItems = items.filter((a) => !a.series);
      return items.length > 0 ? (
        <div class="cat-block">
          <h3 class="cat-label">{cat}</h3>
          {seriesItems.length > 0 && (
            <div class="series-sub">
              <p class="sub-label">Synergeion 시리즈</p>
              <div class="app-grid">{seriesItems.map((app) => <AppCard app={app} />)}</div>
            </div>
          )}
          {studioItems.length > 0 && (
            <div class="series-sub">
              {seriesItems.length > 0 && <p class="sub-label studio">단독 앱</p>}
              <div class="app-grid">{studioItems.map((app) => <AppCard app={app} />)}</div>
            </div>
          )}
        </div>
      ) : null;
    })}

    {soon.length > 0 && (
      <>
        <div class="section-head soon-head"><h2>준비 중</h2></div>
        <div class="app-grid">
          {soon.map((app) => <AppCard app={app} />)}
        </div>
      </>
    )}
  </section>

  <section class="wrap youtube">
    <h3 class="cat-label">영상</h3>
    <a class="yt-card" href={YT_URL} target="_blank" rel="noopener" aria-label="로직크래프트 YouTube 채널 열기">
      <span class="yt-play" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="34" height="34" fill="#fff"><path d="M8 5v14l11-7z" /></svg>
      </span>
      <span class="yt-meta">
        <span class="yt-name">로직크래프트 YouTube</span>
        <span class="yt-handle">@logiccraftmovie</span>
        <span class="yt-blurb">제품 이야기와 사고력 콘텐츠를 영상으로 만나보세요.</span>
      </span>
      <span class="yt-go">채널 보기 →</span>
    </a>
  </section>

  <section class="wrap book">
    <h3 class="cat-label">도서</h3>
    <article class="card book-card">
      <a class="cover" href={BOOK_URL} target="_blank" rel="noopener">
        <img src="/book-cover.jpg" alt="당연함을 의심하는 연습 표지" width="170" height="255" loading="lazy" />
      </a>
      <div class="book-meta">
        <h3>당연함을 의심하는 연습</h3>
        <p class="byline">최우식 지음 · 수필·자기계발 · 2026 · 132쪽</p>
        <p class="book-blurb">
          자기·사랑·사회·일상·배움 — 5가지 영역의 당연함을 49편의 짧은 에세이로 의심합니다.
        </p>
        <a class="btn btn-primary" href={BOOK_URL} target="_blank" rel="noopener">교보문고에서 보기</a>
      </div>
    </article>
  </section>

</Layout>

<style>
  h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); font-weight: 800; margin: 0; }
  .lede {
    margin: 1.4rem 0 0;
    max-width: 40ch;
    font-size: clamp(1rem, 2.2vw, 1.18rem);
    color: rgba(255, 255, 255, 0.82);
  }
  .lede b { color: #fff; }
  .cta { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2.2rem; }
  .ghost-dark { color: #fff; border-color: rgba(255, 255, 255, 0.28); }
  .ghost-dark:hover { color: #fff; border-color: var(--accent-soft); }

  /* ── Synergeion 피처 (밝은 톤) ── */
  .syn-feature {
    background:
      radial-gradient(130% 95% at 85% -10%, rgba(37, 99, 235, 0.10), transparent 55%),
      linear-gradient(180deg, #ffffff, var(--series-soft));
    color: var(--ink);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .brandline {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: var(--accent-deep);
    margin: 0 0 1.4rem;
  }
  .syn-top {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .syn-copy h2 { font-size: clamp(1.45rem, 3vw, 1.95rem); margin: 0; font-weight: 800; line-height: 1.3; }
  .vision {
    margin: 1.4rem 0 0;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--accent-deep);
  }
  .value { margin: 0.3rem 0 0; color: var(--muted); font-size: 0.95rem; }
  .syn-cta { margin-top: var(--space-7); }

  .mascots { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .mascot { margin: 0; text-align: center; }
  .mascot img {
    width: 210px;
    height: auto;
    background: var(--mascot-bg);
    border-radius: 24px;
    box-shadow: var(--shadow-lg);
  }
  .mascot figcaption {
    margin-top: 0.6rem;
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--ink);
  }
  .mascot figcaption span {
    color: var(--accent-deep);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    margin-left: 0.3rem;
  }

  @media (max-width: 760px) {
    .syn-top { grid-template-columns: 1fr; gap: 1.8rem; }
    .mascots { order: -1; }
    .mascot img { width: 160px; }
  }

  /* ── 제품 ── */
  .section-head .sub { color: var(--sub); margin: 0.4rem 0 0; font-size: 0.95rem; }
  .series-sub { margin-bottom: var(--space-5); }
  .sub-label {
    margin: 0 0 var(--space-3);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }
  .sub-label.studio { color: var(--muted); }
  .soon-head { margin-top: 3rem; }
  #products { padding-bottom: 1.5rem; }

  /* ── 도서 ── */
  .book { padding-top: 1rem; }
  .book-card {
    display: flex;
    gap: var(--space-7);
    flex-wrap: wrap;
    align-items: flex-start;
  }
  .book-card:hover { transform: none; }
  .book .cover {
    flex-shrink: 0;
    display: block;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(20, 22, 28, 0.16);
    transition: transform 0.16s ease;
  }
  .book .cover:hover { transform: translateY(-3px); }
  .book .cover img { display: block; width: 170px; height: auto; }
  .book-meta { flex: 1; min-width: 260px; }
  .book-meta h3 { margin: 0; font-size: 1.3rem; font-weight: 800; }
  .byline { margin: 0.5rem 0 0; color: var(--muted); font-size: 0.9rem; }
  .book-blurb { margin: 1rem 0 1.5rem; color: var(--sub); font-size: 0.98rem; line-height: 1.75; max-width: 54ch; }

  /* ── 영상 (YouTube) ── */
  .youtube { padding-top: 1rem; }
  .yt-card {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding: var(--space-6) var(--space-7);
    border: 1px solid var(--border);
    border-radius: 14px;
    background: linear-gradient(180deg, #fff, #fdf2f2);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .yt-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .yt-play {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: #ff0033;
    box-shadow: 0 8px 22px rgba(255, 0, 51, 0.32);
  }
  .yt-meta { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 220px; }
  .yt-name { font-size: 1.2rem; font-weight: 800; }
  .yt-handle { font-size: 0.85rem; font-weight: 700; color: #d3002b; }
  .yt-blurb { margin-top: 0.3rem; color: var(--sub); font-size: 0.95rem; }
  .yt-go { font-weight: 800; color: var(--accent-deep); white-space: nowrap; }
</style>
