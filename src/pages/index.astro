---
import Layout from '../layouts/Layout.astro';
import ListRow from '../components/ListRow.astro';
import { products } from '../data/products.js';

const eduItems = products.filter((p) => p.section === 'edu' && !p.lab);
const dailyItems = products.filter((p) => p.section === 'daily' && !p.lab);
const labItems = products.filter((p) => p.lab);
// Wonder 는 피처 카드로 별도 렌더(아래 마크업). Build 는 series(카운트용)라 데이터에 카드 필드가 없어 인라인 정의.
const buildCard = { group: 'thinking', slug: 'build', icon: 'build', name: 'Synergeion Build', chip: '6–9세', type: 'app', desc: '직접 만들고 부수며 원리를 익히는 사고력 놀이.' };

// 교육 하위 분류 — 어린이 사고력은 Wonder(피처) + Build + thinking 항목.
const thinkingRows = [buildCard, ...eduItems.filter((p) => p.group === 'thinking')];
const examItems = eduItems.filter((p) => p.group === 'exam');
const practicalItems = eduItems.filter((p) => p.group === 'practical');
const eduGroups = [
  { label: '어린이 사고력', rows: thinkingRows, count: 1 + thinkingRows.length }, // +Wonder 피처
  { label: '시험·자격', rows: examItems, count: examItems.length },
  { label: '실용·자기주도', rows: practicalItems, count: practicalItems.length },
];
const eduCount = eduGroups.reduce((n, g) => n + g.count, 0);
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <canvas class="hero-net" id="heroNet" aria-hidden="true"></canvas>
    <div class="wrap">
      <div class="hero-inner">
        <div class="hero-text reveal">
          <p class="eyebrow on-dark">LOGICCRAFT · 사고력 EdTech 스튜디오</p>
          <h1>생각하는 힘을 키우는 <em>공간</em>을 만듭니다.</h1>
          <div class="hero-cta">
            <a href="/apps" class="btn btn-primary">제품 보기 <span class="arr">→</span></a>
            <a href="/about" class="btn btn-ghost">스튜디오 소개</a>
          </div>
        </div>
        <a class="tile youtube light reveal" href="https://www.youtube.com/@NaruandNeti" target="_blank" rel="noopener">
          <div class="yt-thumb">
            <img src="/mascots/naru-neti-scene.png" alt="나루와 느티" />
            <div class="yt-mark"></div>
          </div>
          <div class="yt-row">
            <div>
              <h3>나루와 느티 YouTube</h3>
              <p class="handle">@NaruandNeti</p>
            </div>
            <span class="go">채널 보기 <span class="arr">→</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ SYNERGEION ============ -->
  <section class="synergeion" id="synergeion" style="padding-block: clamp(35px, 4.5vw, 60px)">
    <div class="wrap">
      <div class="syn-copy reveal" style="text-align:center; max-width:720px; margin:0 auto">
        <p class="eyebrow">SYNERGEION · 대표 시리즈</p>
        <h2 class="section-title">3세부터 18세까지, 하나의 여정으로 이어집니다.</h2>
      </div>
      <div class="syn-strip-wrap reveal">
        <div class="syn-strip" id="synStrip">
          <div class="syn-step" style="--st: var(--st-wonder)">
            <span class="dot">01</span><span class="ln">Wonder</span><span class="ag">3–6세</span><span class="tag live">출시</span>
          </div>
          <div class="syn-step" style="--st: var(--st-build)">
            <span class="dot">02</span><span class="ln">Build</span><span class="ag">6–9세</span><span class="tag live">출시</span>
          </div>
          <div class="syn-step" style="--st: var(--st-voyage)">
            <span class="dot">03</span><span class="ln">Voyage</span><span class="ag">9–12세</span><span class="tag soon">예정</span>
          </div>
          <div class="syn-step" style="--st: var(--st-forge)">
            <span class="dot">04</span><span class="ln">Forge</span><span class="ag">12–15세</span><span class="tag soon">예정</span>
          </div>
          <div class="syn-step" style="--st: var(--st-village)">
            <span class="dot">05</span><span class="ln">Village</span><span class="ag">15–18세</span><span class="tag soon">예정</span>
          </div>
        </div>
      </div>
      <div class="reveal" style="text-align:center; margin-top: clamp(32px,4vw,44px)">
        <a href="/apps" class="btn btn-dark">시리즈 자세히 보기 <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ CAMPUS ============ -->
  <section class="campus" id="campus">
    <div class="wrap">
      <div class="campus-card reveal">
        <a class="campus-map" href="https://synergeion-campus-production.up.railway.app" target="_blank" rel="noopener" aria-label="시너지언 캠퍼스 웹에서 둘러보기">
          <img src="/campus-map.png" alt="시너지언 캠퍼스 지도 — Wonder·Think·Build·Voyage·Village 하우스가 중앙 광장을 둘러싼 아이소메트릭 섬" loading="lazy" />
          <span class="campus-badge">웹 · 베타</span>
        </a>
        <div class="campus-body">
          <p class="eyebrow">SYNERGEION CAMPUS · 웹에서 둘러보기</p>
          <h2 class="section-title">걸어서 둘러보는 배움의 캠퍼스.</h2>
          <p class="campus-desc">다섯 하우스와 광장이 있는 시너지언 캠퍼스를 브라우저에서 직접 걸어 둘러봐요. 하우스에 다가가면 그 안의 배움 도구가 열리고, 광장에서는 함께 온 사람들을 만나요. 설치나 가입은 필요 없어요.</p>
          <div class="campus-cta">
            <a class="btn btn-primary" href="https://synergeion-campus-production.up.railway.app" target="_blank" rel="noopener">캠퍼스 입장하기 <span class="arr">→</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PRODUCTS ============ -->
  <section class="products" id="products" style="padding-top:clamp(20px,3vw,36px)">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">PRODUCTS · 우리가 만든 도구</p>
      </div>

      <!-- 교육 -->
      <div class="section-block" style="margin-top: clamp(32px,4vw,52px)">
        <div class="cat-head reveal">
          <span class="label">교육</span>
          <span class="rule"></span>
          <span class="count">{String(eduCount).padStart(2, '0')}</span>
        </div>

        <!-- 어린이 사고력 -->
        <div class="subgroup">
          <div class="subcat reveal">
            <span class="label">어린이 사고력</span>
            <span class="rule"></span>
            <span class="count">{String(eduGroups[0].count).padStart(2, '0')}</span>
          </div>
          <!-- Featured: Wonder -->
          <article class="pcard feature reveal" style="margin-bottom: 14px">
            <div class="feat-art">
              <div class="mascot-float">
                <a class="mascot-panel" id="mascotPanel" href="https://www.youtube.com/@NaruandNeti" target="_blank" rel="noopener" aria-label="나루와 느티 유튜브 채널 열기">
                  <div class="glare"></div>
                  <div class="mascot-row">
                    <img class="naru" src="/mascots/naru.png" alt="나루 — 아기 비버 마스코트" />
                    <img class="neti" src="/mascots/neti.png" alt="느티 — 새싹 정령 마스코트" />
                  </div>
                  <div class="mascot-caption">
                    <div class="m"><b>나루</b><span>NARU</span></div>
                    <div class="m"><b>느티</b><span>NETI</span></div>
                  </div>
                </a>
              </div>
            </div>
            <div class="feat-body">
              <p class="eyebrow warm">SYNERGEION 시리즈 · 출시</p>
              <div class="name-row"><h3>Synergeion Wonder</h3><span class="chip">3–6세</span></div>
              <p class="desc">아이와 부모가 함께 자라는 사고력 정원. 매일 씨앗 한 알, 부모도 같이 자랍니다.</p>
              <div class="links">
                <a href="https://apps.apple.com/kr/app/synergeion-wonder/id6774041352">App Store</a>
                <a href="https://play.google.com/store/apps/details?id=kr.logiccraft.wonder">Google Play</a>
              <div class="legal">
                <a class="muted" href="/apps/wonder/">자세히</a>
                <a class="muted" href="/apps/wonder/support">지원</a>
                <a class="muted" href="/apps/wonder/privacy">개인정보</a>
                <a class="muted" href="/apps/wonder/terms">약관</a>
              </div>
              </div>
            </div>
          </article>

          <div class="list-rows">
            {thinkingRows.map((p) => <ListRow p={p} />)}
          </div>
        </div>

        {eduGroups.slice(1).map((g) => (
          <div class="subgroup">
            <div class="subcat reveal">
              <span class="label">{g.label}</span>
              <span class="rule"></span>
              <span class="count">{String(g.count).padStart(2, '0')}</span>
            </div>
            <div class="list-rows">
              {g.rows.map((p) => <ListRow p={p} />)}
            </div>
          </div>
        ))}
      </div>

      <!-- 일상 -->
      <div class="section-block">
        <div class="cat-head daily reveal">
          <span class="label">일상</span>
          <span class="rule"></span>
          <span class="count">{String(dailyItems.length).padStart(2, '0')}</span>
        </div>
        <div class="list-rows">
          {dailyItems.map((p) => <ListRow p={p} />)}
        </div>
      </div>

      <!-- 실험실 -->
      <div class="section-block">
        <div class="cat-head lab reveal">
          <span class="label">베타 실험실</span>
          <span class="rule"></span>
          <span class="count">{String(labItems.length).padStart(2, '0')}</span>
        </div>
        <p class="section-lead" style="margin: -14px 0 22px">가볍게 실험 중인 웹 도구들.</p>
        <div class="list-rows">
          {labItems.map((p) => <ListRow p={p} />)}
        </div>
      </div>

      <div class="reveal" style="text-align:center; margin-top: clamp(36px,4.5vw,52px)">
        <a href="/apps" class="btn btn-dark">전체 제품 자세히 보기 <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ MEDIA + BOOK ============ -->
  <section class="media-band">
    <div class="wrap">
      <div class="reveal" style="margin-bottom: 30px">
        <p class="eyebrow">MORE · 영상과 글</p>
        <h2 class="section-title" style="color:#fff">제품 너머의 이야기.</h2>
      </div>
      <div class="media-grid">
        <a class="tile youtube reveal" href="https://www.youtube.com/@logiccraftmovie">
          <div class="yt-mark"></div>
          <h3>로직크래프트 YouTube</h3>
          <p class="handle">@logiccraftmovie</p>
          <p>제품 이야기와 사고력 콘텐츠를 영상으로 만나보세요.</p>
          <span class="go">채널 보기 <span class="arr">→</span></span>
        </a>
        <a class="tile book reveal" href="https://product.kyobobook.co.kr/detail/S000219252300">
          <div class="book-cover">
            <img src="/book-cover.jpg" alt="당연함을 의심하는 연습 표지" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <div class="cover-fallback" style="display:none"><b>당연함을<br />의심하는 연습</b><span>최우식 지음</span></div>
          </div>
          <div>
            <p class="meta">최우식 지음 · 수필·자기계발 · 2026 · 132쪽</p>
            <h3>당연함을 의심하는 연습</h3>
            <p>자기·사랑·사회·일상·배움 — 5가지 영역의 당연함을 49편의 짧은 에세이로 의심합니다.</p>
            <span class="go">교보문고에서 보기 <span class="arr">→</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
