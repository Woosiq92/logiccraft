---
import Layout from '../layouts/Layout.astro';

const principles = [
  {
    title: '한 가지를 또렷하게',
    body: '기능을 늘리기보다 하나의 쓸모를 정확히 해결합니다. 군더더기 없는 앱이 오래 쓰입니다.',
  },
  {
    title: '생각을 돕는 쪽으로',
    body: '시간을 빼앗는 앱이 아니라, 사고력·판단력을 한 뼘 키우는 앱을 지향합니다.',
  },
  {
    title: '직접 만들고 끝까지 책임',
    body: '기획·디자인·개발·출시·운영을 직접 합니다. 만든 사람이 끝까지 돌봅니다.',
  },
];
---

<Layout
  title="소개 — 로직크래프트 LogicCraft"
  description="로직크래프트(LogicCraft)는 사고력을 키우는 앱을 만드는 1인 앱 스튜디오입니다. 대표자 최우식."
>
  <section class="wrap page-head">
    <img class="logo-full" src="/logo-full.png" alt="로직크래프트 LogicCraft 로고" width="200" />
    <p class="eyebrow">소개</p>
    <h1>작은 도구가<br />생각을 바꾼다고 믿습니다.</h1>
    <p class="intro">
      로직크래프트(LogicCraft)는 사고력·판단력을 키우는 모바일 앱을 만드는 1인 앱 스튜디오입니다.
      코딩 퍼즐부터 과학 사고 게임, 기록 도구, 시세 모니터까지 — 분야는 달라도
      "사람의 생각을 한 뼘 거든다"는 한 방향을 봅니다.
    </p>
    <p class="logo-note">
      로고는 <strong>물음표</strong>와 <strong>둘러앉아 토론하는 탁자</strong>를 형상화했습니다 —
      질문을 던지고, 함께 생각한다는 뜻입니다.
    </p>
  </section>

  <section class="wrap">
    <div class="principles">
      {principles.map((p, i) => (
        <div class="principle">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="wrap">
    <div class="biz-card">
      <h2>사업자 정보</h2>
      <dl>
        <div><dt>상호</dt><dd>로직크래프트 (LogicCraft)</dd></div>
        <div><dt>대표자</dt><dd>최우식</dd></div>
        <div><dt>사업자등록번호</dt><dd>302-11-03141</dd></div>
        <div><dt>문의</dt><dd><a href="mailto:smartsikhye@gmail.com">smartsikhye@gmail.com</a></dd></div>
      </dl>
    </div>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 1rem; }
  .logo-full { width: 200px; height: auto; margin-bottom: 1.6rem; }
  .page-head h1 { font-size: clamp(2rem, 5vw, 2.9rem); margin: 0.3rem 0 0; }
  .intro { color: var(--sub); margin: 1.2rem 0 0; max-width: 58ch; font-size: 1.05rem; }
  .logo-note {
    margin: 1.4rem 0 0;
    max-width: 52ch;
    color: var(--muted);
    font-size: 0.95rem;
    border-left: 3px solid var(--accent);
    padding-left: 0.9rem;
  }
  .logo-note strong { color: var(--sub); }

  .principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }
  @media (max-width: 720px) { .principles { grid-template-columns: 1fr; } }
  .principle {
    padding: 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-alt);
  }
  .principle .num { font-weight: 800; color: var(--accent); font-size: 0.9rem; letter-spacing: 0.05em; }
  .principle h3 { margin: 0.5rem 0 0.5rem; font-size: 1.15rem; }
  .principle p { margin: 0; color: var(--sub); font-size: 0.94rem; }

  .biz-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .biz-card h2 { margin: 0 0 1.2rem; font-size: 1.3rem; }
  dl { margin: 0; display: grid; gap: 0.8rem; }
  dl > div { display: flex; gap: 1rem; }
  dt { width: 130px; flex-shrink: 0; color: var(--muted); font-weight: 600; }
  dd { margin: 0; font-weight: 600; }
</style>
