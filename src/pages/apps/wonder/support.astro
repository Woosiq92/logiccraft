---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '인터넷 없이도 되나요?',
    a: '네. Wonder는 오늘의 놀이부터 기록까지 모두 기기 안에서 작동합니다. 모든 정보는 부모의 기기에만 저장되고 서버로 전송되지 않아요.',
  },
  {
    q: '아이가 직접 쓰는 앱인가요?',
    a: '아니요. 부모와 아이가 함께 보며, 입력·기록은 부모가 합니다. "진짜 사용자는 부모"라는 생각으로 만든 부모-아이 공동 놀이예요.',
  },
  {
    q: '아이를 똑똑하게 만들어 주나요?',
    a: '그렇게 약속하지 않습니다. Wonder는 정답을 가르치는 앱이 아니라, "왜?·만약?" 같은 좋은 질문을 함께 나누는 습관을 돕는 도구예요. 발달 성과를 보장하지 않습니다.',
  },
  {
    q: '광고나 결제가 있나요?',
    a: '광고·AI는 쓰지 않습니다. 무료로 내려받아 앞 3개 놀이를 해볼 수 있고, 마음에 들면 일회성 인앱 결제(₩6,900)로 전체 놀이를 평생 잠금해제합니다. 구독이 아니며 자동 갱신도 없습니다.',
  },
  {
    q: '기록을 옮기거나 백업할 수 있나요?',
    a: '헛간 → 데이터·백업에서 백업 파일(JSON) 저장·복원, 텍스트 내보내기를 할 수 있어요. 기기를 바꾸기 전 백업해 두는 것을 권합니다.',
  },
  {
    q: '기록을 지우고 싶어요.',
    a: '헛간 → 데이터·백업 → 기록 초기화, 또는 앱 삭제로 모든 데이터를 지울 수 있습니다. 지운 기록은 휴지통에 30일 보관 후 영구 삭제됩니다.',
  },
];
---

<Layout
  title="Synergeion Wonder — 고객 지원 · 로직크래프트"
  description="Synergeion Wonder 고객 지원. 자주 묻는 질문과 문의 안내."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>Synergeion Wonder</h1>
    <p>매일 씨앗 한 알, 부모도 자랍니다.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 기능 제안, 환불·데이터 권리, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[Synergeion Wonder] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/wonder/privacy">개인정보 처리방침</a> · <a href="/apps/wonder/terms">이용약관</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
