---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '인터넷 없이도 되나요?',
    a: '네. Build는 오늘의 "정말 그래?"부터 탐정 놀이·상상 놀이·기록까지 모두 기기 안에서 작동합니다. 모든 정보는 기기에만 저장되고 서버로 전송되지 않아요.',
  },
  {
    q: '아이가 직접 쓰는 앱인가요?',
    a: '아이가 직접 하되, 부모가 곁에서 함께 보는 6~9세 부모-아이 사고력 놀이예요. 설정·기록 관리는 부모 몫이에요.',
  },
  {
    q: '아이를 똑똑하게 만들어 주나요?',
    a: '그렇게 약속하지 않습니다. Build는 정답을 가르치는 앱이 아니라, "정말 그래?·왜 그럴까?"를 스스로 묻고 직접 확인해 보는 생각 습관을 돕는 도구예요. 발달·학업 성과를 보장하지 않습니다.',
  },
  {
    q: '카메라·마이크는 왜 쓰나요?',
    a: '탐정 놀이에서 아이가 찾은 답을 사진·그림·음성으로 담을 때만 사용합니다. 사진·그림은 기기에만 저장되고, 음성은 텍스트로 바뀐 결과만 저장돼요. 외부 전송은 없습니다.',
  },
  {
    q: '광고나 인앱 결제가 있나요?',
    a: '없습니다. 광고·인앱 결제·AI를 쓰지 않습니다. 스토어에서 한 번 구매하는 유료 앱입니다.',
  },
  {
    q: '기록을 옮기거나 백업할 수 있나요?',
    a: '설정 탭 → 데이터·백업에서 백업 파일(JSON) 저장·복원, 텍스트 내보내기를 할 수 있어요. 기록은 이 기기에만 저장되니 기기를 바꾸기 전 백업해 두는 것을 권합니다.',
  },
  {
    q: '기록을 지우고 싶어요.',
    a: '설정 탭 → 데이터·백업 → "앱 전체 초기화", 또는 앱 삭제로 모든 데이터를 지울 수 있습니다.',
  },
];
---

<Layout
  title="Synergeion Build — 고객 지원 · 로직크래프트"
  description="Synergeion Build 고객 지원. 자주 묻는 질문과 문의 안내."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>Synergeion Build</h1>
    <p>매일 한 번 "정말 그래?", 스스로 생각하는 아이로.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 기능 제안, 환불·데이터 권리, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[Synergeion Build] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/build/privacy">개인정보 처리방침</a> · <a href="/apps/build/terms">이용약관</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
