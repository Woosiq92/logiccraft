---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '프롬프트 도장은 어떤 앱인가요?',
    a: 'AI 프롬프트 작성 능력을 게임처럼 단련하는 연습 앱입니다. 매번 새로 생성되는 문제를 풀고 즉시 채점받으며, 맥락 채우기 → 형식 고정 → 사고 절차 → 검증 가능한 목표화 4단계를 차근차근 통과합니다. 코딩·글쓰기·영상 세 트랙과 용도별 하위분류(디버깅·코드리뷰·릴스·광고 등)로 나뉘어 있어요.',
  },
  {
    q: '채점은 어떻게 되나요? AI를 쓰나요?',
    a: '모든 채점은 기기 안에서 규칙 기반으로 즉시 이뤄집니다. 외부 AI를 호출하지 않아 빠르고, 인터넷 없이도 동작하며, 결과가 매번 일관됩니다. 채점 후에는 무엇이 빠졌는지와 "모범 예시"를 함께 보여줍니다.',
  },
  {
    q: '로그인이 필요한가요? 무료로 어디까지 쓰나요?',
    a: '회원가입·로그인은 필요 없습니다. 코딩·글쓰기·영상 모든 트랙의 L1(맥락 채우기)은 무료로 풀 수 있습니다. L2(형식 고정)부터 L4(검증 가능한 목표화)까지는 "전체 이용"으로 열립니다.',
  },
  {
    q: '전체 이용은 어떻게 구성되나요?',
    a: '구독이 아닌 일회성 구매입니다. 전체 이용(₩7,900)을 한 번 구매하면 세 트랙의 모든 레벨이 영구히 잠금 해제되고, 기기를 바꿔도 복원할 수 있습니다.',
  },
  {
    q: '구매를 복원하려면 어떻게 하나요?',
    a: '잠긴 레벨의 결제 화면 또는 설정 탭의 "구매 복원" 버튼을 누르면 전체 이용이 복원됩니다. 결제·환불은 App Store·Google Play를 통해 처리되며, 영수증·환불 문의는 각 스토어 정책을 따릅니다.',
  },
  {
    q: '같은 문제가 반복되지 않나요?',
    a: '문제는 풀 때마다 규칙 기반 생성기로 새로 조립됩니다. 트랙·하위분류·레벨에 따라 다른 문제가 나오고, 한 레벨에서 연속 3문제를 맞히면 다음 레벨이 열립니다. 네 레벨을 모두 통과하면 무작위 혼합 "마스터" 모드가 열립니다.',
  },
  {
    q: '학습 내용의 정확성은 보장되나요?',
    a: '문제와 채점은 학습 참고용으로 제공되며, 특정 결과나 성과를 보장하지 않습니다. 프롬프트 작성의 일반 원칙을 단련하는 도구로 활용해 주세요. 개선점이나 오류를 발견하시면 알려주시면 반영하겠습니다.',
  },
  {
    q: '내 기록을 초기화하고 싶어요.',
    a: '진도·연속 기록·누적 통계 등 모든 학습 기록은 기기 내부에만 저장됩니다. 설정 탭의 "진행 초기화"로 지우거나, 앱을 제거하면 함께 삭제됩니다.',
  },
];
---

<Layout
  title="프롬프트 도장 — 고객 지원 · 로직크래프트"
  description="프롬프트 도장 고객 지원. 자주 묻는 질문과 문의 안내. AI 프롬프트 작성 능력을 게임처럼 단련하는 연습 앱."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>프롬프트 도장</h1>
    <p>읽지 말고 망가뜨리고 고친다 — 프롬프트 작성 단련.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 문제 오류 제보, 기능 제안, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[프롬프트 도장] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/prompt-dojo/privacy">개인정보 처리방침</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
