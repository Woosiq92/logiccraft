---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '프롬프트 도장은 무엇인가요?',
    a: 'AI에게 잘 부탁하는 법(프롬프트)을 문제로 풀며 익히는 무료 웹 연습 도구입니다. 매번 새로 생성되는 문제를 풀고 즉시 채점받으며, 좋은 프롬프트의 5가지 — 맥락 채우기 · 출력 지정 · 추론 확보 · 검증 가능한 목표화, 그리고 역할·자료 제공 — 를 차근차근 익힙니다. 기초(일상 예시)·코딩·글쓰기·영상 네 트랙으로 나뉘어 있어요.',
  },
  {
    q: '돈을 내야 하나요? 로그인이 필요한가요?',
    a: '웹 버전은 가입·로그인·결제 없이 모든 트랙을 무료로 풀 수 있습니다. 설치도 필요 없고 브라우저에서 바로 시작됩니다.',
  },
  {
    q: '채점은 어떻게 되나요? AI를 쓰나요?',
    a: '모든 채점은 기기(브라우저) 안에서 규칙 기반으로 즉시 이뤄집니다. 외부 AI를 호출하지 않아 빠르고, 결과가 매번 일관됩니다. 채점은 "좋은 프롬프트의 5가지가 빠짐없이 들었는지(완성도)"를 보며, 무엇이 빠졌는지와 "모범 예시"를 함께 보여줍니다. (실제로 원하는 결과가 나오는지는 결과로 판단해야 하므로, 완성도 연습 도구로 활용해 주세요.)',
  },
  {
    q: '낮은 단계와 높은 단계가 다른가요?',
    a: '같은 스킬이라도 익숙해지기 전(숙련도가 낮을 때)에는 "무엇이 빠졌나 고르기" 같은 객관식이 나오고, 정답을 쌓아 익숙해지면 직접 프롬프트를 써내는 주관식으로 넘어갑니다. 알아보기 → 써내기 순서로 단계가 올라갑니다.',
  },
  {
    q: '같은 문제가 반복되지 않나요?',
    a: '문제는 풀 때마다 규칙 기반 생성기로 새로 조립됩니다. 한 스킬에서 정답을 5개 쌓으면 그 스킬을 "익힘" 처리하고 다음 스킬로 넘어가며, 네 가지를 모두 익히면 무작위 혼합 "마스터" 모드가 열립니다.',
  },
  {
    q: '학습 내용의 정확성은 보장되나요?',
    a: '문제와 채점은 학습 참고용으로 제공되며, 특정 결과나 성과를 보장하지 않습니다. 구체적 기법(예시 개수, 단계 지시 여부 등)은 사용하는 AI·버전마다 다를 수 있으니, 변하지 않는 원칙을 익히는 도구로 활용해 주세요. 개선점이나 오류를 발견하시면 알려주시면 반영하겠습니다.',
  },
  {
    q: '내 기록을 초기화하고 싶어요.',
    a: '숙련도·연속 기록·누적 통계 등 모든 학습 기록은 브라우저 내부에만 저장되며 외부로 전송되지 않습니다. 설정 탭의 "진행 초기화"로 지우거나, 브라우저 데이터를 삭제하면 함께 사라집니다.',
  },
];
---

<Layout
  title="프롬프트 도장 — 고객 지원 · 로직크래프트"
  description="프롬프트 도장 고객 지원. 자주 묻는 질문과 문의 안내. AI 프롬프트 작성 능력을 게임처럼 단련하는 연습 앱."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>프롬프트 도장</h1>
    <p>읽지 말고 망가뜨리고 고친다 — 프롬프트 작성 단련.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 문제 오류 제보, 기능 제안, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[프롬프트 도장] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/prompt-dojo/privacy">개인정보 처리방침</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
