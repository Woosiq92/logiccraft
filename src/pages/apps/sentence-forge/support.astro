---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '글벼림은 어떤 앱인가요?',
    a: '근대문학 명문장을 문장 단위로 뜯어보고, 그 기법으로 내 문장을 직접 고쳐보는 글쓰기 훈련 앱입니다. 읽기(명문장 해부), 벼리기(문장 고치기 연습), 문장첩(내 문장 수집)의 세 축으로 문장력을 키웁니다.',
  },
  {
    q: '로그인이 필요한가요? 유료인가요?',
    a: '회원가입·로그인이 필요 없고, 광고와 인앱결제도 없습니다. 모든 기능을 처음부터 무료로 씁니다. 인터넷 연결 없이 오프라인으로 동작합니다.',
  },
  {
    q: '벼리기는 어떻게 채점하나요?',
    a: '일부러 못 쓴 문장을 규칙 기반으로 채점합니다. 중복 덜기·번역투 걷기·피동을 능동으로·압축·문장 쪼개기 등 8가지 기법별로, 고치면 그 자리에서 결과와 모범 예시를 보여줍니다. 정답은 하나가 아니며 모범 예시와 견주어 표현을 익히는 방식입니다.',
  },
  {
    q: '문장첩은 무엇인가요?',
    a: '어디서든 만난 좋은 문장을 분류해 모으거나, 오늘·읽기에서 명문장을 본떠 내 문장을 써서 담는 나만의 문장 수집함입니다. 채점하지 않으며, 좋은 문장을 본떠 표현을 익히는 공간입니다.',
  },
  {
    q: '레벨과 칭호는 어떻게 오르나요?',
    a: '벼리기 정답, 명문장 읽기, 문장첩 담기 세 가지를 고루 채우면 습작생 → 문장가 → 문장 장인 → 명필 → 문장의 대가로 칭호가 오릅니다. 한 번 오른 칭호는 내려가지 않습니다.',
  },
  {
    q: '수록된 문학 작품의 저작권은 괜찮나요?',
    a: '저작권 보호기간이 끝난 근대문학(저자 사망 후 70년 경과)만 수록했습니다. 김소월·현진건·이상·정지용·김유정 등 88편의 명문장을 다룹니다.',
  },
  {
    q: '내 학습 기록을 백업하거나 초기화하고 싶어요.',
    a: '레벨·연속·정답률·문장첩 등 모든 기록은 기기 내부에만 저장됩니다. 성장 탭에서 "기록 내보내기"로 파일 백업, "기록 가져오기"로 복원, "기록 초기화"로 삭제할 수 있습니다. 앱을 제거하면 함께 삭제됩니다.',
  },
];
---

<Layout
  title="글벼림 — 고객 지원 · 로직크래프트"
  description="글벼림 고객 지원. 자주 묻는 질문과 문의 안내. 명문장을 뜯어보고 내 문장을 다듬는 무료 글쓰기 훈련 앱."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>글벼림</h1>
    <p>읽고 · 고치고 · 모으고 — 문장력을 키우는 글쓰기 훈련.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 오류 제보, 기능 제안, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[글벼림] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/sentence-forge/privacy">개인정보 처리방침</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
