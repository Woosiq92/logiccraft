---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '교논 트레이너는 어떤 앱인가요?',
    a: '중등 임용 1교시 교육학 논술을 대비하는 학습 앱입니다. 흩어진 교육학 이론을 매일 암기하고(읽기·빈칸 퀴즈·개념 회상·암기카드), 기출 객관식으로 점검하고, 기출 논제를 실전으로 작성한 뒤 모범 필수 키워드로 셀프 채점하는 인출 연습 중심의 훈련소입니다.',
  },
  {
    q: '로그인이 필요한가요? 유료인가요?',
    a: '회원가입·로그인이 없고 무료로 씁니다. 광고도 없고, 현재 유료 결제(인앱구매)도 없습니다. 모든 학습 콘텐츠가 앱 안에 포함되어 있어 인터넷 없이도 동작합니다.',
  },
  {
    q: '하루에 어떻게 공부하나요?',
    a: '오늘 탭에서 오늘의 개념 하나를 읽기 → 빈칸 퀴즈 → 개념 회상 3단계로 익히고, 망각곡선 만기 복습이 있으면 ‘오늘 복습’으로 먼저 굳힙니다. 기출 개념을 한 바퀴 다 익히면 전체 개념으로 이어집니다.',
  },
  {
    q: '빈칸 퀴즈와 복습은 어떻게 작동하나요?',
    a: '핵심어를 직접 채우는 빈칸 퀴즈를 안다·애매·모른다로 답하면 망각곡선(간격 반복)에 맞춰 다시 출제됩니다. 만기된 복습은 오늘 탭 상단 ‘오늘 복습’ 카드로 모입니다.',
  },
  {
    q: '기출 논제는 어떻게 연습하나요?',
    a: '기출 탭에서 논제를 고르고 개요(뼈대) 짜기로 요구항목을 본론 문단에 배치해 본 뒤, 실전 작성에서 타이머를 켜고 답안을 씁니다. 제출하면 같은 화면에서 모범 필수 키워드 체크리스트로 직접 채점하고, 놓친 요구항목은 회독용으로 모입니다.',
  },
  {
    q: '암기카드를 직접 만들 수 있나요?',
    a: '네. 학습 탭의 암기카드 또는 노트 탭에서 앞면·뒷면을 입력해 나만의 카드를 만들고, 편집·삭제할 수 있습니다. 익힌(암기 완료한) 개념과 직접 만든 카드가 한 덱으로 모여 넘겨볼 수 있습니다.',
  },
  {
    q: '학습 자료의 정확성은 보장되나요?',
    a: '자료와 문제는 학습 참고용으로 제공되며 합격이나 점수를 보장하지 않습니다. 출제 범위·기준·기출 정보는 바뀔 수 있으니 최신·정확한 내용은 시험 주관처(한국교육과정평가원 등) 공식 자료로 확인해 주세요. 오류를 발견하시면 알려주시면 반영하겠습니다.',
  },
  {
    q: '내 학습 기록을 초기화하고 싶어요.',
    a: '진척·익힘·빈칸 복습·객관식·논제 채점·형광펜·직접 만든 카드 등 모든 기록은 기기 내부에만 저장됩니다. 노트 탭의 ‘학습 데이터 초기화’로 비우거나 앱을 제거하면 함께 삭제됩니다. (시험일·환경설정은 유지)',
  },
  {
    q: '데이터를 백업할 수 있나요?',
    a: '노트 탭의 ‘데이터 백업’으로 학습 기록을 JSON 파일로 내보낼 수 있습니다(공유 시트를 통해 파일 앱 등에 저장).',
  },
];
---

<Layout
  title="교논 트레이너 — 고객 지원 · 로직크래프트"
  description="교논 트레이너(교육학 논술 트레이너) 고객 지원. 자주 묻는 질문과 문의 안내. 중등 임용 교육학 논술을 대비하는 무료 학습 앱."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>교논 트레이너</h1>
    <p>이론을 답안으로 엮다 — 교육학 논술 인출 훈련소.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 자료 오류 제보, 기능 제안, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[교논 트레이너] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/eduessay/privacy">개인정보 처리방침</a> · <a href="/apps/eduessay/terms">이용약관</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
