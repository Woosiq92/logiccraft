---
import Layout from '../../../layouts/Layout.astro';

const faqs = [
  {
    q: '해내기는 어떤 앱인가요?',
    a: '해낼 일을 한 줄로 선언하고, 매일 사진·영상·한 줄로 과정을 기록한 뒤, 끝에 해냄/못함을 스스로 증명하는 앱입니다. 기록한 사진은 마지막에 한 편의 회고 영상이 됩니다. 원하면 친구 서클을 만들어 친구가 "가능/못해"에 걸 수도 있어요.',
  },
  {
    q: '로그인이 필요한가요?',
    a: '회원가입·로그인은 없습니다. 혼자 쓰는 선언·기록·증명·회고 영상은 모두 기기 안에서 동작합니다. 친구 서클 기능만 익명 식별자로 서버와 연결됩니다.',
  },
  {
    q: '친구 베팅(가능/못해)은 어떻게 하나요?',
    a: '친구 탭에서 서클을 만들고 초대코드를 공유하거나, 받은 코드로 들어갑니다. 선언을 서클에 공유하면 친구들이 "넌 할 수 있어(가능)" 또는 "손모가지 건다(못해)"에 걸 수 있어요. 베팅은 진행 중 보이고 순위는 매기지 않습니다.',
  },
  {
    q: '사진과 영상은 어디에 저장되나요?',
    a: '매일 기록으로 찍거나 고른 사진·영상은 기기 안에만 저장됩니다. 서버로 업로드되지 않으며, 회고 영상 합성도 기기에서 처리됩니다. 앱을 제거하면 함께 삭제됩니다.',
  },
  {
    q: '회고 영상은 무엇인가요?',
    a: '챌린지 동안 기록한 사진들을 모아 "Day N · 선언" 자막과 마지막 "해냈다" 화면이 들어간 한 편의 세로 영상으로 만들어 줍니다. 상세 화면의 "회고 영상 만들기"에서 만들고 저장할 수 있어요.',
  },
  {
    q: '카메라·사진 권한은 왜 필요한가요?',
    a: '매일 기록에 넣을 사진·영상을 촬영하거나 앨범에서 고르기 위해서만 사용합니다. 선택한 항목만 기기에 저장되고 보관함 전체를 임의로 읽지 않습니다.',
  },
  {
    q: '기록과 서클 데이터를 지우고 싶어요.',
    a: '기기에 저장된 선언·기록·사진·영상은 앱에서 직접 삭제하거나 앱을 제거하면 사라집니다. 친구 서클로 서버에 저장된 정보 삭제는 데이터 삭제 안내를 참고해 문의해 주세요.',
  },
];
---

<Layout
  title="해내기 — 고객 지원 · 로직크래프트"
  description="해내기 고객 지원. 자주 묻는 질문과 문의 안내. 선언하고, 매일 기록하고, 증명하는 앱."
>
  <section class="wrap page-head">
    <p class="eyebrow">고객 지원</p>
    <h1>해내기</h1>
    <p>선언하고 · 매일 기록하고 · 증명한다.</p>
  </section>

  <section class="wrap faq">
    <h2>자주 묻는 질문</h2>
    {faqs.map((f) => (
      <div class="qa">
        <p class="q">Q. {f.q}</p>
        <p class="a">{f.a}</p>
      </div>
    ))}
  </section>

  <section class="wrap contact">
    <h2>문의하기</h2>
    <p class="muted">버그 신고, 기능 제안, 데이터 삭제, 그 외 모든 문의</p>
    <a class="mail" href="mailto:logiccraftmarketing@gmail.com?subject=[해내기] 문의">logiccraftmarketing@gmail.com</a>
    <p class="muted small">평일 24시간 내 회신 드립니다.</p>
    <p class="links"><a href="/apps/haenaegi/privacy">개인정보 처리방침</a> · <a href="/apps/haenaegi/delete-data">데이터 삭제</a> · <a href="/apps">← 제품 목록</a></p>
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .page-head h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.3rem 0 0; }
  .page-head p { color: var(--sub); margin: 0.8rem 0 0; }
  .faq { padding-top: 1rem; max-width: 760px; }
  .faq h2, .contact h2 { font-size: 1.3rem; }
  .qa { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .qa:last-child { border-bottom: none; }
  .q { font-weight: 700; margin: 0 0 0.4rem; }
  .a { color: var(--sub); margin: 0; line-height: 1.7; }
  .contact { padding-top: 2rem; padding-bottom: 4rem; max-width: 760px; }
  .contact .mail {
    display: inline-block; margin: 0.4rem 0; padding: 0.7rem 1.5rem;
    background: var(--accent); color: #fff; border-radius: 999px; font-weight: 700;
  }
  .muted { color: var(--sub); }
  .small { font-size: 0.9rem; }
  .links { margin-top: 1.5rem; font-size: 0.95rem; }
</style>
