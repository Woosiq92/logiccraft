---
import Layout from '../../layouts/Layout.astro';

const guides = [
  {
    href: '/guides/cert-study-method',
    cat: '학습법',
    title: '자격증, 짧게 붙는 사람들의 5단계 공부법',
    excerpt: '시험을 빨리 통과하는 사람은 더 오래 공부하는 사람이 아니라, 공부의 순서가 다른 사람입니다. 출제 기준에서 시작해 기출로 끝나는 다섯 단계를 정리했습니다.',
  },
  {
    href: '/guides/coding-before-code',
    cat: '코딩 교육',
    title: '코딩을 시작하는 아이, 코드보다 먼저 길러야 할 네 가지',
    excerpt: '프로그래밍 언어를 일찍 가르치는 것보다 중요한 것은 분해·패턴·추상화·디버깅이라는 네 가지 사고 습관입니다. 코드 없이 이 힘을 기르는 법.',
  },
  {
    href: '/guides/talk-with-young-kids',
    cat: '부모-아이',
    title: '3~6세 아이와 “왜?”를 나누는 대화법',
    excerpt: '정답을 알려 주는 대화는 호기심을 닫고, 되묻는 대화는 호기심을 엽니다. 매일 몇 분이면 되는, 아이의 생각을 한 걸음 더 밀어 주는 질문법.',
  },
  {
    href: '/guides/psat-triage',
    cat: '시험 전략',
    title: 'PSAT 시간이 모자란 진짜 이유 — “버리기”의 기술',
    excerpt: 'PSAT에서 점수를 가르는 것은 실력보다 “언제 버릴지”를 아는 판단입니다. 매몰비용에 발목 잡히지 않고 시간을 배분하는 법.',
  },
  {
    href: '/guides/read-news-better',
    cat: '시사 입문',
    title: '시사가 어려운 사람을 위한, 뉴스 헤드라인 읽는 법',
    excerpt: '같은 사건도 매체마다 제목이 다릅니다. 어느 쪽이 옳은지 고르기 전에, 표현의 차이를 알아보는 눈을 먼저 기르는 방법.',
  },
];
---

<Layout
  title="가이드 — 학습·사고력·시험 전략 · 로직크래프트"
  description="로직크래프트가 제품을 만들며 정리한 학습법, 코딩 교육, 부모-아이 대화법, 시험 전략, 시사 입문 가이드를 모았습니다."
>
  <section class="wrap page-head">
    <p class="eyebrow">GUIDES · 가이드</p>
    <h1>만들면서 알게 된 것들.</h1>
    <p class="lede">
      로직크래프트는 학습과 사고력을 다루는 제품을 만듭니다. 그 과정에서 정리한 공부법과
      교육 이야기를 누구나 읽을 수 있도록 풀어 두었습니다.
    </p>
  </section>

  <section class="wrap list">
    {guides.map((g) => (
      <a class="card" href={g.href}>
        <span class="cat">{g.cat}</span>
        <h2>{g.title}</h2>
        <p>{g.excerpt}</p>
        <span class="more">읽기 →</span>
      </a>
    ))}
  </section>
</Layout>

<style>
  .page-head { padding-top: 3.5rem; padding-bottom: 0.5rem; }
  .eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 0.8rem; letter-spacing: 0.08em; color: var(--clay); margin: 0; }
  .page-head h1 { font-size: clamp(1.9rem, 5vw, 2.8rem); margin: 0.4rem 0 0; line-height: 1.2; }
  .lede { color: var(--sub); margin: 1rem 0 0; line-height: 1.8; max-width: 720px; }
  .list { padding-top: 2rem; padding-bottom: 4rem; display: grid; gap: 1rem; max-width: 820px; }
  .card { display: block; border: 1px solid var(--line); border-radius: 16px; padding: 1.4rem 1.6rem; text-decoration: none; color: inherit; transition: border-color .15s, transform .15s; }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .card .cat { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--clay); letter-spacing: 0.05em; }
  .card h2 { font-size: 1.2rem; margin: 0.4rem 0 0.5rem; line-height: 1.35; }
  .card p { color: var(--sub); line-height: 1.7; margin: 0; font-size: 0.97rem; }
  .card .more { display: inline-block; margin-top: 0.8rem; color: var(--accent); font-weight: 700; font-size: 0.92rem; }
</style>
