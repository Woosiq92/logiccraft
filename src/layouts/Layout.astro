---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = '로직크래프트 LogicCraft — 생각하는 힘을 키우는 제품',
  description = '로직크래프트(LogicCraft)는 사고력·판단력을 키우는 앱과 학습 플랫폼을 만드는 회사입니다.',
  image = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '로직크래프트',
  alternateName: 'LogicCraft',
  url: 'https://logiccraft.co.kr',
  email: 'logiccraftmarketing@gmail.com',
  description,
  founder: { '@type': 'Person', name: '최우식' },
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta name="naver-site-verification" content="b7885929178d4fd414be2ec0c64781930b23c3c9" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="로직크래프트" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#1a2754" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} is:inline />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="/site.js" is:inline></script>
    <script src="/constellation.js" is:inline></script>
  </body>
</html>
