---
// Interactive 3D hero — the LogicCraft logo, brought to life: a bold ring (the
// table) with 4 lozenge nodes (top/bottom blue, left/right light) and the "?".
// People at the table raise questions that flow into the question mark.
---

<section class="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-overlay">
    <div class="wrap">
      <slot />
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(120% 95% at 76% 8%, #122a5e 0%, transparent 52%),
      radial-gradient(100% 90% at 22% 96%, #0a1226 0%, transparent 55%),
      #060912;
    color: #fff;
  }
  #hero-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .hero-overlay { position: relative; z-index: 2; width: 100%; padding: 6rem 0; pointer-events: none; }
  .hero-overlay :global(a) { pointer-events: auto; }
  .hero-fade {
    position: absolute; left: 0; right: 0; bottom: 0; height: 120px; z-index: 1;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    try {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.12;

      const BLUE = 0x2563eb;
      const LIGHT = 0xeaf2ff;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(48, 1, 0.1, 100);
      const camBase = new THREE.Vector3(0, 0.5, 12);
      const target = new THREE.Vector3(0, 0.4, 0);
      camera.position.copy(camBase);
      camera.lookAt(target);

      // mark = the logo, living in 3D; gentle wobble + parallax keeps it readable
      const mark = new THREE.Group();
      scene.add(mark);
      let markX = 2.4;
      mark.position.set(markX, 0.4, 0);

      // textures
      function dotTexture() {
        const c = document.createElement('canvas'); c.width = c.height = 64;
        const x = c.getContext('2d')!;
        const g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)'); g.addColorStop(0.4, 'rgba(255,255,255,0.6)'); g.addColorStop(1, 'rgba(255,255,255,0)');
        x.fillStyle = g; x.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      }
      function questionTexture() {
        const c = document.createElement('canvas'); c.width = c.height = 160;
        const x = c.getContext('2d')!;
        x.strokeStyle = '#fff'; x.fillStyle = '#fff';
        x.lineWidth = 16; x.lineCap = 'round'; x.lineJoin = 'round';
        x.beginPath();
        x.arc(80, 58, 30, Math.PI * 0.86, Math.PI * 0.18, false);
        x.quadraticCurveTo(105, 100, 80, 108);
        x.stroke();
        x.beginPath(); x.arc(80, 134, 9, 0, Math.PI * 2); x.fill();
        return new THREE.CanvasTexture(c);
      }
      const DOT = dotTexture();
      const QMARK = questionTexture();

      // --- the ring (table) ---
      const R = 2.15;
      const ringCenter = new THREE.Vector3(1.3, 0, 0); // ring sits on the right of the mark
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(R, 0.26, 20, 140),
        new THREE.MeshBasicMaterial({ color: LIGHT })
      );
      ring.position.copy(ringCenter);
      mark.add(ring);
      // soft halo behind the ring
      const halo = new THREE.Sprite(new THREE.SpriteMaterial({ map: DOT, color: 0x3b82f6, transparent: true, opacity: 0.35, depthWrite: false, blending: THREE.AdditiveBlending }));
      halo.scale.setScalar(7); halo.position.copy(ringCenter);
      mark.add(halo);

      // --- 4 lozenge nodes (top/bottom blue, left/right light) ---
      const nodeGeo = new THREE.CapsuleGeometry(0.26, 0.62, 8, 18);
      const NR = R + 0.46; // nodes sit just OUTSIDE the ring, like the logo's tabs
      const nodeDefs = [
        { ang: Math.PI / 2, color: BLUE, rotZ: Math.PI / 2 },   // top — horizontal lozenge
        { ang: -Math.PI / 2, color: BLUE, rotZ: Math.PI / 2 },  // bottom — horizontal
        { ang: 0, color: LIGHT, rotZ: 0 },                      // right — vertical
        { ang: Math.PI, color: LIGHT, rotZ: 0 },                // left — vertical
      ];
      type Node = { mesh: THREE.Mesh; mat: THREE.MeshBasicMaterial; base: THREE.Color; local: THREE.Vector3; next: number; glow: number; world: THREE.Vector3 };
      const nodes: Node[] = [];
      for (const d of nodeDefs) {
        const local = new THREE.Vector3(ringCenter.x + Math.cos(d.ang) * NR, Math.sin(d.ang) * NR, 0);
        const base = new THREE.Color(d.color);
        const mat = new THREE.MeshBasicMaterial({ color: base.clone() });
        const mesh = new THREE.Mesh(nodeGeo, mat);
        mesh.position.copy(local);
        mesh.rotation.z = d.rotZ;
        mark.add(mesh);
        nodes.push({ mesh, mat, base, local, next: 1 + Math.random() * 4, glow: 0, world: new THREE.Vector3() });
      }

      // --- the question mark (left element of the logo) ---
      const qPos = new THREE.Vector3(-2.4, 0.15, 0);
      const bigQMat = new THREE.SpriteMaterial({ map: QMARK, color: LIGHT, transparent: true, opacity: 0.6, depthWrite: false, blending: THREE.AdditiveBlending });
      const bigQ = new THREE.Sprite(bigQMat);
      bigQ.scale.setScalar(3.0);
      bigQ.position.copy(qPos);
      mark.add(bigQ);
      let qPulse = 0; // brightens when a question arrives
      const qWorld = new THREE.Vector3();

      // --- idea pulses: node → question mark ---
      type P = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; t: number; from: THREE.Vector3; to: THREE.Vector3 };
      const ppool: P[] = [];
      for (let i = 0; i < 12; i++) {
        const mat = new THREE.SpriteMaterial({ map: DOT, color: 0x93c5fd, transparent: true, opacity: 0, depthWrite: false, blending: THREE.AdditiveBlending });
        const sp = new THREE.Sprite(mat); sp.scale.setScalar(0.5); sp.visible = false; scene.add(sp);
        ppool.push({ sp, mat, t: 1, from: new THREE.Vector3(), to: new THREE.Vector3() });
      }

      function ask(n: Node) {
        const p = ppool.find((p) => p.t >= 1);
        if (p) { p.from.copy(n.world); p.to.copy(qWorld); p.t = 0; p.sp.visible = true; }
      }

      const pointer = { x: 0, y: 0, has: false };
      window.addEventListener('pointermove', (e) => {
        pointer.x = (e.clientX / window.innerWidth) * 2 - 1;
        pointer.y = -((e.clientY / window.innerHeight) * 2 - 1);
        pointer.has = true;
      }, { passive: true });
      window.addEventListener('pointerleave', () => (pointer.has = false));

      function resize() {
        const r = canvas!.getBoundingClientRect();
        const w = r.width || window.innerWidth;
        const h = r.height || window.innerHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h; camera.updateProjectionMatrix();
        markX = camera.aspect < 0.95 ? 0.6 : 2.4;
        mark.position.x = markX;
      }
      window.addEventListener('resize', resize);
      resize();

      const ndc = new THREE.Vector3();
      const hot = new THREE.Color(0xffffff);
      let time = 0;

      function update(dt: number) {
        time += dt;

        // gentle 3D wobble (keeps the logo readable) + parallax
        const px = pointer.has ? pointer.x : 0;
        const py = pointer.has ? pointer.y : 0;
        const wobY = Math.sin(time * 0.5) * 0.28;
        const wobX = Math.sin(time * 0.37) * 0.12;
        mark.rotation.y += (wobY + px * 0.25 - mark.rotation.y) * 0.06;
        mark.rotation.x += (wobX - py * 0.15 - mark.rotation.x) * 0.06;

        bigQ.getWorldPosition(qWorld);
        qPulse = Math.max(0, qPulse - dt * 1.6);
        bigQMat.opacity = 0.55 + Math.sin(time * 1.4) * 0.08 + qPulse * 0.4;
        bigQ.scale.setScalar(3.0 + qPulse * 0.5);

        let nearest = -1, best = 0.22;
        for (let i = 0; i < nodes.length; i++) {
          nodes[i].mesh.getWorldPosition(nodes[i].world);
          if (!pointer.has) continue;
          ndc.copy(nodes[i].world).project(camera);
          const d = Math.hypot(ndc.x - pointer.x, ndc.y - pointer.y);
          if (d < best) { best = d; nearest = i; }
        }

        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i];
          n.glow += ((i === nearest ? 1 : 0) - n.glow) * 0.12;
          n.mat.color.copy(n.base).lerp(hot, n.glow * 0.7);
          const sc = 1 + n.glow * 0.3;
          n.mesh.scale.set(sc, sc, sc);
          n.next -= dt * (1 + n.glow * 5);
          if (n.next <= 0) { ask(n); n.next = i === nearest ? 0.7 + Math.random() * 0.7 : 3.5 + Math.random() * 4; }
        }

        for (const p of ppool) {
          if (p.t >= 1) continue;
          p.t += dt / 1.2;
          const e = p.t * p.t * (3 - 2 * p.t);
          p.sp.position.lerpVectors(p.from, p.to, e);
          p.sp.position.y += Math.sin(e * Math.PI) * 0.5; // arc across the mark
          p.mat.opacity = Math.sin(Math.min(p.t, 1) * Math.PI) * 0.95;
          if (p.t >= 1) { p.sp.visible = false; qPulse = Math.min(1, qPulse + 0.7); } // arrival lights the "?"
        }
      }

      const clock = new THREE.Clock();
      if (reduce) {
        for (let i = 0; i < nodes.length; i++) nodes[i].mesh.getWorldPosition(nodes[i].world);
        update(0); renderer.render(scene, camera);
      } else {
        let raf = 0;
        const loop = () => { update(Math.min(clock.getDelta(), 0.05)); renderer.render(scene, camera); raf = requestAnimationFrame(loop); };
        loop();
        document.addEventListener('visibilitychange', () => {
          cancelAnimationFrame(raf);
          if (!document.hidden) { clock.getDelta(); loop(); }
        });
      }
    } catch (e) {
      console.warn('hero 3D disabled:', e);
    }
  }
</script>
