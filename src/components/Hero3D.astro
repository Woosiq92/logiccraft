---
// Interactive 3D hero — a warm golden-hour conference scene: a round meeting
// table with modern office chairs, backlit by window sun, dust bokeh, lens
// flare. People raise questions ("?") in brand blue — warm discussion, blue ideas.
---

<section class="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-overlay">
    <div class="wrap">
      <slot />
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(120% 95% at 78% 6%, #6a4a1e 0%, transparent 50%),
      radial-gradient(100% 90% at 25% 96%, #1c1409 0%, transparent 55%),
      #0d0a06;
    color: #fff;
  }
  #hero-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .hero-overlay { position: relative; z-index: 2; width: 100%; padding: 6rem 0; pointer-events: none; }
  .hero-overlay :global(a) { pointer-events: auto; }
  .hero-fade {
    position: absolute; left: 0; right: 0; bottom: 0; height: 120px; z-index: 1;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    try {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.05;

      const BLUE = 0x60a5fa;
      const CREAM = 0xe9e1d2;
      const WOOD = 0xd8c3a0;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
      const camBase = new THREE.Vector3(0, 7.6, 9.6); // high 3/4 angle, like the photo
      const target = new THREE.Vector3(0, -0.2, 0);
      camera.position.copy(camBase);
      camera.lookAt(target);

      // --- warm golden-hour lighting ---
      scene.add(new THREE.AmbientLight(0x4a3826, 0.9));
      const sun = new THREE.DirectionalLight(0xffd79a, 2.4); // strong warm backlight (window)
      sun.position.set(7, 9, -6);
      scene.add(sun);
      const fill = new THREE.DirectionalLight(0xffe9cf, 0.55); // soft front fill
      fill.position.set(-4, 5, 8);
      scene.add(fill);
      const tableGlow = new THREE.PointLight(0xffb867, 5.5, 12, 2); // warm pool on the table
      tableGlow.position.set(0, 1.2, 0);

      const table = new THREE.Group();
      scene.add(table);
      table.add(tableGlow);
      let tableX = 2.2;
      table.position.x = tableX;

      // --- round meeting table ---
      const topMat = new THREE.MeshStandardMaterial({ color: WOOD, roughness: 0.45, metalness: 0.05 });
      const top = new THREE.Mesh(new THREE.CylinderGeometry(3.2, 3.2, 0.22, 64), topMat);
      top.position.y = 0;
      table.add(top);
      const pedestal = new THREE.Mesh(
        new THREE.CylinderGeometry(0.5, 0.9, 1.5, 32),
        new THREE.MeshStandardMaterial({ color: 0x6f5c44, roughness: 0.5, metalness: 0.2 })
      );
      pedestal.position.y = -0.85;
      table.add(pedestal);

      // --- shared geometries / materials for modern office chairs ---
      function roundedRect(w: number, h: number, r: number) {
        const s = new THREE.Shape();
        s.moveTo(-w / 2 + r, -h / 2);
        s.lineTo(w / 2 - r, -h / 2); s.quadraticCurveTo(w / 2, -h / 2, w / 2, -h / 2 + r);
        s.lineTo(w / 2, h / 2 - r); s.quadraticCurveTo(w / 2, h / 2, w / 2 - r, h / 2);
        s.lineTo(-w / 2 + r, h / 2); s.quadraticCurveTo(-w / 2, h / 2, -w / 2, h / 2 - r);
        s.lineTo(-w / 2, -h / 2 + r); s.quadraticCurveTo(-w / 2, -h / 2, -w / 2 + r, -h / 2);
        return s;
      }
      const backGeo = new THREE.ExtrudeGeometry(roundedRect(0.95, 0.95, 0.3), {
        depth: 0.14, bevelEnabled: true, bevelThickness: 0.03, bevelSize: 0.03, bevelSegments: 2,
      });
      const seatGeo = new THREE.BoxGeometry(0.9, 0.14, 0.85);
      const stemGeo = new THREE.CylinderGeometry(0.06, 0.06, 0.95, 12);
      const legGeo = new THREE.BoxGeometry(0.07, 0.05, 0.42);
      const chairMat = new THREE.MeshStandardMaterial({ color: CREAM, roughness: 0.65, metalness: 0.05 });
      const metalMat = new THREE.MeshStandardMaterial({ color: 0xaab0b8, roughness: 0.3, metalness: 0.8 });

      function makeChair() {
        const g = new THREE.Group();
        const back = new THREE.Mesh(backGeo, chairMat); back.position.set(0, 0.62, 0.42); back.rotation.x = -0.14; g.add(back);
        const seat = new THREE.Mesh(seatGeo, chairMat); seat.position.set(0, 0.12, 0.04); g.add(seat);
        const stem = new THREE.Mesh(stemGeo, metalMat); stem.position.set(0, -0.4, 0.04); g.add(stem);
        for (let k = 0; k < 5; k++) {
          const leg = new THREE.Mesh(legGeo, metalMat);
          const aa = (k / 5) * Math.PI * 2;
          leg.position.set(Math.sin(aa) * 0.2, -0.85, 0.04 + Math.cos(aa) * 0.2);
          leg.rotation.y = aa;
          g.add(leg);
        }
        return g;
      }

      // --- people seated around the table ---
      const SEATS = 8;
      const R_CHAIR = 4.0;
      const R_PERSON = 3.35;
      type Seat = { person: THREE.Mesh; mat: THREE.MeshStandardMaterial; base: THREE.Color; next: number; glow: number; world: THREE.Vector3 };
      const seats: Seat[] = [];

      for (let i = 0; i < SEATS; i++) {
        const a = (i / SEATS) * Math.PI * 2;
        const chair = makeChair();
        chair.position.set(Math.sin(a) * R_CHAIR, 0, Math.cos(a) * R_CHAIR);
        chair.rotation.y = a; // front faces center
        table.add(chair);

        const base = new THREE.Color(0xf0d9b8);
        const mat = new THREE.MeshStandardMaterial({ color: base.clone(), roughness: 0.5, emissive: 0x3a2a14, emissiveIntensity: 0.3 });
        const person = new THREE.Mesh(new THREE.SphereGeometry(0.3, 24, 24), mat);
        person.scale.set(1, 1.3, 1);
        person.position.set(Math.sin(a) * R_PERSON, 0.55, Math.cos(a) * R_PERSON);
        table.add(person);
        seats.push({ person, mat, base, next: 1.5 + Math.random() * 5, glow: 0, world: new THREE.Vector3() });
      }

      // --- textures ---
      function dotTexture(soft = false) {
        const c = document.createElement('canvas'); c.width = c.height = 64;
        const x = c.getContext('2d')!;
        const g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)');
        g.addColorStop(soft ? 0.5 : 0.4, 'rgba(255,255,255,0.6)');
        g.addColorStop(1, 'rgba(255,255,255,0)');
        x.fillStyle = g; x.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      }
      function questionTexture() {
        const c = document.createElement('canvas'); c.width = c.height = 128;
        const x = c.getContext('2d')!;
        x.fillStyle = '#fff'; x.font = 'bold 96px -apple-system, BlinkMacSystemFont, system-ui, sans-serif';
        x.textAlign = 'center'; x.textBaseline = 'middle'; x.fillText('?', 64, 72);
        return new THREE.CanvasTexture(c);
      }
      const DOT = dotTexture();
      const SOFT = dotTexture(true);
      const QMARK = questionTexture();

      // --- sun flare (fake, additive sprites) ---
      function flare(scaleN: number, x: number, y: number, z: number, opacity: number, color: number) {
        const sp = new THREE.Sprite(new THREE.SpriteMaterial({ map: SOFT, color, transparent: true, opacity, depthWrite: false, blending: THREE.AdditiveBlending }));
        sp.scale.setScalar(scaleN); sp.position.set(x, y, z); scene.add(sp);
      }
      flare(11, 6.5, 6.5, -6, 0.5, 0xffe6b0);
      flare(4, 3.5, 4.2, -3, 0.35, 0xffd9a0);
      flare(1.6, 1.5, 2.6, -1, 0.3, 0xfff0d0);

      // --- dust bokeh in the sunlight ---
      const BOKEH = 28;
      const bpos = new Float32Array(BOKEH * 3);
      const bsiz = new Float32Array(BOKEH);
      for (let i = 0; i < BOKEH; i++) {
        bpos[i * 3] = (Math.random() * 2 - 1) * 8;
        bpos[i * 3 + 1] = Math.random() * 7 - 1;
        bpos[i * 3 + 2] = (Math.random() * 2 - 1) * 5 - 1;
        bsiz[i] = 0.08 + Math.random() * 0.32;
      }
      const bgeo = new THREE.BufferGeometry();
      bgeo.setAttribute('position', new THREE.BufferAttribute(bpos, 3));
      bgeo.setAttribute('size', new THREE.BufferAttribute(bsiz, 1));
      const bokeh = new THREE.Points(
        bgeo,
        new THREE.PointsMaterial({ map: DOT, color: 0xffdca0, size: 0.32, transparent: true, opacity: 0.5, depthWrite: false, blending: THREE.AdditiveBlending, sizeAttenuation: true })
      );
      scene.add(bokeh);

      // --- rising "?" (brand blue) + pulse pools ---
      type Q = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; life: number; max: number; from: THREE.Vector3 };
      const qpool: Q[] = [];
      for (let i = 0; i < 10; i++) {
        const mat = new THREE.SpriteMaterial({ map: QMARK, color: BLUE, transparent: true, opacity: 0, depthWrite: false, blending: THREE.AdditiveBlending });
        const sp = new THREE.Sprite(mat); sp.scale.setScalar(1); sp.visible = false; scene.add(sp);
        qpool.push({ sp, mat, life: 0, max: 1, from: new THREE.Vector3() });
      }
      type P = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; t: number; from: THREE.Vector3 };
      const ppool: P[] = [];
      for (let i = 0; i < 14; i++) {
        const mat = new THREE.SpriteMaterial({ map: DOT, color: 0xffe6c0, transparent: true, opacity: 0, depthWrite: false, blending: THREE.AdditiveBlending });
        const sp = new THREE.Sprite(mat); sp.scale.setScalar(0.45); sp.visible = false; scene.add(sp);
        ppool.push({ sp, mat, t: 1, from: new THREE.Vector3() });
      }
      const center = new THREE.Vector3(tableX, 0.6, 0);

      function ask(s: Seat) {
        const q = qpool.find((q) => q.life <= 0);
        if (q) { q.from.copy(s.world); q.life = q.max = 2.4 + Math.random() * 0.8; q.sp.visible = true; }
        const p = ppool.find((p) => p.t >= 1);
        if (p) { p.from.copy(s.world); p.t = 0; p.sp.visible = true; }
      }

      const pointer = { x: 0, y: 0, has: false };
      window.addEventListener('pointermove', (e) => {
        pointer.x = (e.clientX / window.innerWidth) * 2 - 1;
        pointer.y = -((e.clientY / window.innerHeight) * 2 - 1);
        pointer.has = true;
      }, { passive: true });
      window.addEventListener('pointerleave', () => (pointer.has = false));

      function resize() {
        const r = canvas!.getBoundingClientRect();
        const w = r.width || window.innerWidth;
        const h = r.height || window.innerHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h; camera.updateProjectionMatrix();
        tableX = camera.aspect < 0.95 ? 0.5 : 2.2;
        table.position.x = tableX;
        center.x = tableX;
      }
      window.addEventListener('resize', resize);
      resize();

      const ndc = new THREE.Vector3();
      const up = new THREE.Vector3(0, 1, 0);
      const hot = new THREE.Color(0xfff2dc);

      function update(dt: number) {
        table.rotation.y += 0.1 * dt;

        const px = pointer.has ? pointer.x : 0;
        const py = pointer.has ? pointer.y : 0;
        camera.position.x += (camBase.x + px * 2.4 - camera.position.x) * 0.05;
        camera.position.y += (camBase.y - py * 1.2 - camera.position.y) * 0.05;
        camera.lookAt(target);

        // drifting dust
        const bp = bgeo.attributes.position as THREE.BufferAttribute;
        for (let i = 0; i < BOKEH; i++) {
          let y = bp.getY(i) + dt * 0.25;
          if (y > 6.5) y = -1;
          bp.setY(i, y);
          bp.setX(i, bp.getX(i) + Math.sin(y * 0.6 + i) * dt * 0.12);
        }
        bp.needsUpdate = true;

        let nearest = -1, best = 0.24;
        for (let i = 0; i < SEATS; i++) {
          seats[i].person.getWorldPosition(seats[i].world);
          if (!pointer.has) continue;
          ndc.copy(seats[i].world).project(camera);
          const d = Math.hypot(ndc.x - pointer.x, ndc.y - pointer.y);
          if (d < best) { best = d; nearest = i; }
        }

        for (let i = 0; i < SEATS; i++) {
          const s = seats[i];
          s.glow += ((i === nearest ? 1 : 0) - s.glow) * 0.12;
          s.mat.color.copy(s.base).lerp(hot, s.glow * 0.6);
          s.mat.emissiveIntensity = 0.3 + s.glow * 0.9;
          const sc = 1 + s.glow * 0.35;
          s.person.scale.set(sc, 1.3 * sc, sc);
          s.next -= dt * (1 + s.glow * 5);
          if (s.next <= 0) { ask(s); s.next = i === nearest ? 0.9 + Math.random() * 0.9 : 5 + Math.random() * 5; }
        }

        for (const q of qpool) {
          if (q.life <= 0) continue;
          q.life -= dt;
          const t = 1 - q.life / q.max;
          q.sp.position.copy(q.from).addScaledVector(up, 0.6 + t * 2.8);
          q.sp.scale.setScalar(1.0 + t * 0.9);
          q.mat.opacity = Math.sin(Math.min(t, 1) * Math.PI);
          if (q.life <= 0) q.sp.visible = false;
        }
        for (const p of ppool) {
          if (p.t >= 1) continue;
          p.t += dt / 1.1;
          const e = p.t * p.t * (3 - 2 * p.t);
          p.sp.position.lerpVectors(p.from, center, e);
          p.mat.opacity = (1 - p.t) * 0.85;
          if (p.t >= 1) p.sp.visible = false;
        }
      }

      const clock = new THREE.Clock();
      if (reduce) {
        for (let i = 0; i < SEATS; i++) seats[i].person.getWorldPosition(seats[i].world);
        update(0); renderer.render(scene, camera);
      } else {
        let raf = 0;
        const loop = () => { update(Math.min(clock.getDelta(), 0.05)); renderer.render(scene, camera); raf = requestAnimationFrame(loop); };
        loop();
        document.addEventListener('visibilitychange', () => {
          cancelAnimationFrame(raf);
          if (!document.hidden) { clock.getDelta(); loop(); }
        });
      }
    } catch (e) {
      console.warn('hero 3D disabled:', e);
    }
  }
</script>
