---
// Interactive 3D hero — the geometry of a round table + a thinking network.
// Concentric rings, 12 nodes on a circle, a {12/5} star web, spokes to a glowing
// core, questions ("?") rising and idea-pulses flowing inward. Brand blue/white.
---

<section class="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-overlay">
    <div class="wrap">
      <slot />
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(120% 95% at 76% 8%, #122a5e 0%, transparent 52%),
      radial-gradient(100% 90% at 22% 96%, #0a1226 0%, transparent 55%),
      #060912;
    color: #fff;
  }
  #hero-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .hero-overlay { position: relative; z-index: 2; width: 100%; padding: 6rem 0; pointer-events: none; }
  .hero-overlay :global(a) { pointer-events: auto; }
  .hero-fade {
    position: absolute; left: 0; right: 0; bottom: 0; height: 120px; z-index: 1;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    try {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.1;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
      const camBase = new THREE.Vector3(0, 5.8, 10.6); // elevated → rings read as a round table
      const target = new THREE.Vector3(0, 0, 0);
      camera.position.copy(camBase);
      camera.lookAt(target);

      // rig: tilts/parallax; spin: continuous rotation of the geometry
      const rig = new THREE.Group();
      const spin = new THREE.Group();
      rig.add(spin);
      scene.add(rig);
      let tableX = 2.2;
      rig.position.x = tableX;

      // --- textures ---
      function dotTexture() {
        const c = document.createElement('canvas'); c.width = c.height = 64;
        const x = c.getContext('2d')!;
        const g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)'); g.addColorStop(0.4, 'rgba(255,255,255,0.65)'); g.addColorStop(1, 'rgba(255,255,255,0)');
        x.fillStyle = g; x.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      }
      function questionTexture() {
        const c = document.createElement('canvas'); c.width = c.height = 128;
        const x = c.getContext('2d')!;
        x.fillStyle = '#fff'; x.font = 'bold 96px -apple-system, BlinkMacSystemFont, system-ui, sans-serif';
        x.textAlign = 'center'; x.textBaseline = 'middle'; x.fillText('?', 64, 72);
        return new THREE.CanvasTexture(c);
      }
      const DOT = dotTexture();
      const QMARK = questionTexture();

      // --- concentric rings (the round table, as pure geometry) ---
      const R_OUT = 4.2;
      function ring(r: number, tube: number, opacity: number, color: number) {
        const m = new THREE.Mesh(
          new THREE.TorusGeometry(r, tube, 12, 160),
          new THREE.MeshBasicMaterial({ color, transparent: true, opacity, depthWrite: false, blending: THREE.AdditiveBlending })
        );
        m.rotation.x = Math.PI / 2;
        spin.add(m);
        return m;
      }
      ring(R_OUT, 0.018, 0.55, 0x60a5fa);
      ring(2.7, 0.012, 0.3, 0x3b82f6);
      ring(1.25, 0.012, 0.35, 0x3b82f6);

      // --- 12 nodes evenly on the outer circle ---
      const N = 12;
      type Node = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; base: THREE.Color; r0: number; local: THREE.Vector3; next: number; glow: number; world: THREE.Vector3 };
      const nodes: Node[] = [];
      for (let i = 0; i < N; i++) {
        const a = (i / N) * Math.PI * 2;
        const local = new THREE.Vector3(Math.cos(a) * R_OUT, 0, Math.sin(a) * R_OUT);
        const accent = i % 3 === 0;
        const base = new THREE.Color(accent ? 0x3b82f6 : 0xdbeafe);
        const mat = new THREE.SpriteMaterial({ map: DOT, color: base.clone(), transparent: true, opacity: 0.95, depthWrite: false, blending: THREE.AdditiveBlending });
        const r0 = accent ? 0.5 : 0.4;
        const sp = new THREE.Sprite(mat);
        sp.scale.setScalar(r0);
        sp.position.copy(local);
        spin.add(sp);
        nodes.push({ sp, mat, base, r0, local, next: 1.5 + Math.random() * 5, glow: 0, world: new THREE.Vector3() });
      }

      // --- network: {12/5} star web + spokes to the core ---
      const segs: number[] = [];
      const seen = new Set<string>();
      for (let i = 0; i < N; i++) {
        const j = (i + 5) % N; // {12/5} star polygon
        const key = i < j ? `${i}-${j}` : `${j}-${i}`;
        if (!seen.has(key)) { seen.add(key); const a = nodes[i].local, b = nodes[j].local; segs.push(a.x, a.y, a.z, b.x, b.y, b.z); }
      }
      const starGeo = new THREE.BufferGeometry();
      starGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(segs), 3));
      const starMat = new THREE.LineBasicMaterial({ color: 0x60a5fa, transparent: true, opacity: 0.32, depthWrite: false, blending: THREE.AdditiveBlending });
      spin.add(new THREE.LineSegments(starGeo, starMat));

      const spokeArr: number[] = [];
      for (let i = 0; i < N; i++) { const a = nodes[i].local; spokeArr.push(a.x, a.y, a.z, 0, 0, 0); }
      const spokeGeo = new THREE.BufferGeometry();
      spokeGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(spokeArr), 3));
      spin.add(new THREE.LineSegments(spokeGeo, new THREE.LineBasicMaterial({ color: 0x2563eb, transparent: true, opacity: 0.16, depthWrite: false, blending: THREE.AdditiveBlending })));

      // --- glowing core + rotating octahedron at the center ---
      const core = new THREE.Group();
      spin.add(core);
      const coreDot = new THREE.Sprite(new THREE.SpriteMaterial({ map: DOT, color: 0xeaf2ff, transparent: true, opacity: 1, depthWrite: false, blending: THREE.AdditiveBlending }));
      coreDot.scale.setScalar(0.7); core.add(coreDot);
      const coreHalo = new THREE.Sprite(new THREE.SpriteMaterial({ map: DOT, color: 0x3b82f6, transparent: true, opacity: 0.4, depthWrite: false, blending: THREE.AdditiveBlending }));
      coreHalo.scale.setScalar(2.2); core.add(coreHalo);
      const octa = new THREE.LineSegments(
        new THREE.EdgesGeometry(new THREE.OctahedronGeometry(0.6)),
        new THREE.LineBasicMaterial({ color: 0x93c5fd, transparent: true, opacity: 0.85, depthWrite: false, blending: THREE.AdditiveBlending })
      );
      core.add(octa);

      // --- rising "?" + idea-pulse pools ---
      type Q = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; life: number; max: number; from: THREE.Vector3 };
      const qpool: Q[] = [];
      for (let i = 0; i < 10; i++) {
        const mat = new THREE.SpriteMaterial({ map: QMARK, color: 0xdbeafe, transparent: true, opacity: 0, depthWrite: false, blending: THREE.AdditiveBlending });
        const sp = new THREE.Sprite(mat); sp.scale.setScalar(1); sp.visible = false; scene.add(sp);
        qpool.push({ sp, mat, life: 0, max: 1, from: new THREE.Vector3() });
      }
      type P = { sp: THREE.Sprite; mat: THREE.SpriteMaterial; t: number; from: THREE.Vector3; to: THREE.Vector3 };
      const ppool: P[] = [];
      for (let i = 0; i < 14; i++) {
        const mat = new THREE.SpriteMaterial({ map: DOT, color: 0x93c5fd, transparent: true, opacity: 0, depthWrite: false, blending: THREE.AdditiveBlending });
        const sp = new THREE.Sprite(mat); sp.scale.setScalar(0.42); sp.visible = false; scene.add(sp);
        ppool.push({ sp, mat, t: 1, from: new THREE.Vector3(), to: new THREE.Vector3() });
      }
      const coreWorld = new THREE.Vector3();

      function ask(n: Node) {
        const q = qpool.find((q) => q.life <= 0);
        if (q) { q.from.copy(n.world); q.life = q.max = 2.4 + Math.random() * 0.8; q.sp.visible = true; }
        const p = ppool.find((p) => p.t >= 1); // idea flows inward to the core
        if (p) { p.from.copy(n.world); p.to.copy(coreWorld); p.t = 0; p.sp.visible = true; }
      }

      const pointer = { x: 0, y: 0, has: false };
      window.addEventListener('pointermove', (e) => {
        pointer.x = (e.clientX / window.innerWidth) * 2 - 1;
        pointer.y = -((e.clientY / window.innerHeight) * 2 - 1);
        pointer.has = true;
      }, { passive: true });
      window.addEventListener('pointerleave', () => (pointer.has = false));

      function resize() {
        const r = canvas!.getBoundingClientRect();
        const w = r.width || window.innerWidth;
        const h = r.height || window.innerHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h; camera.updateProjectionMatrix();
        tableX = camera.aspect < 0.95 ? 0.4 : 2.2;
        rig.position.x = tableX;
      }
      window.addEventListener('resize', resize);
      resize();

      const ndc = new THREE.Vector3();
      const up = new THREE.Vector3(0, 1, 0);
      const hot = new THREE.Color(0xffffff);
      let time = 0;

      function update(dt: number) {
        time += dt;
        spin.rotation.y += 0.12 * dt;
        core.rotation.y += 0.5 * dt;
        core.rotation.x = 0.4;
        coreDot.scale.setScalar(0.6 + Math.sin(time * 2) * 0.12);
        starMat.opacity = 0.26 + Math.sin(time * 1.3) * 0.08; // web breathes

        // parallax tilt
        const px = pointer.has ? pointer.x : 0;
        const py = pointer.has ? pointer.y : 0;
        rig.rotation.y += (px * 0.35 - rig.rotation.y) * 0.05;
        rig.rotation.x += (-py * 0.2 - rig.rotation.x) * 0.05;

        core.getWorldPosition(coreWorld);

        let nearest = -1, best = 0.22;
        for (let i = 0; i < N; i++) {
          nodes[i].sp.getWorldPosition(nodes[i].world);
          if (!pointer.has) continue;
          ndc.copy(nodes[i].world).project(camera);
          const d = Math.hypot(ndc.x - pointer.x, ndc.y - pointer.y);
          if (d < best) { best = d; nearest = i; }
        }

        for (let i = 0; i < N; i++) {
          const n = nodes[i];
          n.glow += ((i === nearest ? 1 : 0) - n.glow) * 0.12;
          n.mat.color.copy(n.base).lerp(hot, n.glow * 0.8);
          n.sp.scale.setScalar(n.r0 + n.glow * 0.5);
          n.next -= dt * (1 + n.glow * 5);
          if (n.next <= 0) { ask(n); n.next = i === nearest ? 0.8 + Math.random() * 0.8 : 4 + Math.random() * 5; }
        }

        for (const q of qpool) {
          if (q.life <= 0) continue;
          q.life -= dt;
          const t = 1 - q.life / q.max;
          q.sp.position.copy(q.from).addScaledVector(up, 0.4 + t * 2.6);
          q.sp.scale.setScalar(1.0 + t * 0.9);
          q.mat.opacity = Math.sin(Math.min(t, 1) * Math.PI);
          if (q.life <= 0) q.sp.visible = false;
        }
        for (const p of ppool) {
          if (p.t >= 1) continue;
          p.t += dt / 1.2;
          const e = p.t * p.t * (3 - 2 * p.t);
          p.sp.position.lerpVectors(p.from, p.to, e);
          p.sp.position.y += Math.sin(e * Math.PI) * 0.4;
          p.mat.opacity = Math.sin(Math.min(p.t, 1) * Math.PI) * 0.95;
          if (p.t >= 1) p.sp.visible = false;
        }
      }

      const clock = new THREE.Clock();
      if (reduce) {
        for (let i = 0; i < N; i++) nodes[i].sp.getWorldPosition(nodes[i].world);
        update(0); renderer.render(scene, camera);
      } else {
        let raf = 0;
        const loop = () => { update(Math.min(clock.getDelta(), 0.05)); renderer.render(scene, camera); raf = requestAnimationFrame(loop); };
        loop();
        document.addEventListener('visibilitychange', () => {
          cancelAnimationFrame(raf);
          if (!document.hidden) { clock.getDelta(); loop(); }
        });
      }
    } catch (e) {
      console.warn('hero 3D disabled:', e);
    }
  }
</script>
