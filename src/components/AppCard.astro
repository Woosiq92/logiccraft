---
import type { AppInfo } from '../data/apps';
interface Props { app: AppInfo; }
const { app } = Astro.props;
---

<article class="card product">
  <img class="icon" src={app.icon} alt="" width="56" height="56" loading="lazy" />
  <div class="head">
    <h3>{app.name}</h3>
    {app.domain && <span class="tag">{app.domain}</span>}
    {app.status === 'soon' && <span class="badge">준비 중</span>}
  </div>
  <p class="blurb">{app.blurb}</p>
  {app.links.length > 0 && (
    <div class="links">
      {app.links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
      ))}
    </div>
  )}
</article>

<style>
  .product {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    object-fit: cover;
    border: 1px solid rgba(26, 39, 84, 0.08);
    box-shadow: 0 2px 8px rgba(26, 39, 84, 0.08);
  }
  .head { display: flex; align-items: center; gap: var(--space-2); }
  .head h3 { margin: 0; font-size: 1.12rem; font-weight: 800; }
  .badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted);
    background: #f3f4f6;
    border-radius: var(--radius-pill);
    padding: 2px 9px;
  }
  .tag {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent-deep);
    background: var(--series-soft, #eef1fb);
    border-radius: var(--radius-pill);
    padding: 2px 9px;
    white-space: nowrap;
  }
  .blurb { margin: 0; color: var(--sub); font-size: 0.94rem; flex: 1; }
  .links { display: flex; flex-wrap: wrap; gap: var(--space-4); font-size: 0.86rem; font-weight: 700; }
  .links a { color: var(--accent-deep); }
</style>
