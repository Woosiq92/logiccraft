---
import type { AppInfo } from '../data/apps';
interface Props { app: AppInfo; }
const { app } = Astro.props;
---

<article class="card">
  <img class="icon" src={app.icon} alt="" width="56" height="56" loading="lazy" />
  <div class="head">
    <h3>{app.name}</h3>
    {app.status === 'soon' && <span class="badge">준비 중</span>}
  </div>
  <p class="blurb">{app.blurb}</p>
  {app.links.length > 0 && (
    <div class="links">
      {app.links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
      ))}
    </div>
  )}
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 34px rgba(20, 22, 28, 0.08);
    border-color: #e0e0e6;
  }
  .icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    object-fit: cover;
    border: 1px solid rgba(20, 22, 28, 0.08);
    box-shadow: 0 2px 8px rgba(20, 22, 28, 0.08);
  }
  .head { display: flex; align-items: center; gap: 0.55rem; }
  .head h3 { margin: 0; font-size: 1.12rem; font-weight: 800; }
  .badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted);
    background: #f3f4f6;
    border-radius: 999px;
    padding: 2px 9px;
  }
  .blurb { margin: 0; color: var(--sub); font-size: 0.94rem; flex: 1; }
  .links { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.86rem; font-weight: 700; }
</style>
