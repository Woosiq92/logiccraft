---
// 앱 다운로드 버튼 — 공식 스토어 배지 스타일. 두 버튼 모두 파란 테두리.
// 방문 기기(iOS/Android)의 버튼을 앞으로 정렬만 한다.
const { ios = null, play = null } = Astro.props;
---
<div class="dl-wrap">
  <div class="dl" data-dl>
    {ios && (
      <a class="dlb" data-store="ios" href={ios} aria-label="App Store에서 다운로드">
        <svg class="dlb-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 12.04c-.03-2.6 2.12-3.85 2.22-3.91-1.21-1.77-3.09-2.01-3.76-2.04-1.6-.16-3.12.94-3.93.94-.81 0-2.06-.92-3.39-.89-1.74.03-3.35 1.01-4.25 2.57-1.81 3.14-.46 7.79 1.3 10.34.86 1.25 1.88 2.65 3.22 2.6 1.29-.05 1.78-.83 3.34-.83 1.56 0 2 .83 3.37.81 1.39-.03 2.27-1.27 3.12-2.53.98-1.45 1.39-2.85 1.41-2.92-.03-.01-2.71-1.04-2.74-4.12zM14.53 4.51c.71-.86 1.19-2.06 1.06-3.25-1.02.04-2.26.68-2.99 1.54-.66.76-1.23 1.98-1.08 3.15 1.14.09 2.3-.58 3.01-1.44z"/></svg>
        <span class="dlb-tx"><small>지금 다운로드</small><b>App Store</b></span>
      </a>
    )}
    {play && (
      <a class="dlb" data-store="play" href={play} aria-label="Google Play에서 다운로드">
        <svg class="dlb-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 3.5v17c0 .8.9 1.3 1.6.9l14-8.5c.7-.4.7-1.4 0-1.8l-14-8.5C4.9 2.2 4 2.7 4 3.5z"/></svg>
        <span class="dlb-tx"><small>지금 다운로드</small><b>Google Play</b></span>
      </a>
    )}
    {ios && !play && <span class="dlb-soon">Google Play 준비 중</span>}
  </div>
</div>

<script is:inline>
  (function () {
    var box = document.querySelector('[data-dl]');
    if (!box) return;
    var ua = navigator.userAgent || '';
    if (/iPhone|iPad|iPod/i.test(ua)) box.classList.add('is-ios');
    else if (/Android/i.test(ua)) box.classList.add('is-android');
  })();
</script>

<style>
  .dl-wrap { margin-top: 1.7rem; display: flex; flex-direction: column; align-items: flex-start; }
  .dl { display: flex; gap: 12px; flex-wrap: wrap; align-items: stretch; }
  .dlb {
    display: inline-flex; align-items: center; gap: 13px;
    min-height: 62px; padding: 10px 24px 10px 20px; border-radius: 15px;
    background: #11183a; color: #fff;
    box-shadow: 0 0 0 3px var(--accent), 0 14px 32px rgba(47, 99, 244, .28);
    transition: transform .2s var(--ease), box-shadow .2s;
  }
  .dlb:hover { transform: translateY(-2px); box-shadow: 0 0 0 3px var(--accent), 0 18px 38px rgba(47, 99, 244, .36); }
  .dlb-ic { width: 27px; height: 27px; flex-shrink: 0; }
  .dlb-tx { display: flex; flex-direction: column; line-height: 1.12; text-align: left; }
  .dlb-tx small { font-size: 12px; font-weight: 500; opacity: .72; white-space: nowrap; }
  .dlb-tx b { font-size: 20px; font-weight: 700; letter-spacing: -.01em; white-space: nowrap; }
  .dlb-soon {
    display: inline-flex; align-items: center; padding: 0 18px; min-height: 62px;
    border-radius: 15px; background: #edece6; color: #9aa1ba; font-weight: 600; font-size: 14px;
  }
  /* 방문 기기에 맞는 버튼을 앞으로 정렬 */
  .dl.is-ios [data-store="ios"],
  .dl.is-android [data-store="play"] { order: 0; }
  .dl.is-ios [data-store="play"],
  .dl.is-android [data-store="ios"] { order: 1; }
  @media (max-width: 520px) {
    .dl-wrap { align-items: stretch; }
    .dl { flex-direction: column; align-items: stretch; }
    .dlb { justify-content: center; }
    .dlb-soon { justify-content: center; }
  }
</style>
