---
const links = [
  { href: '/', label: '홈', meta: 'HOME' },
  { href: '/synergeion', label: 'Synergeion', meta: '3–18' },
  { href: '/apps', label: '제품', meta: 'APPS' },
  { href: '/about', label: '소개', meta: 'ABOUT' },
  { href: '/contact', label: '문의', meta: 'CONTACT' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
// contextual CTA: product pages push to 문의, everywhere else pushes to 제품
const cta = path === '/apps' || path === '/about'
  ? { href: '/contact', label: '문의하기' }
  : { href: '/apps', label: '제품 보기' };
---

<header class="site-header" id="header">
  <div class="wrap nav">
    <a class="brand" href="/" aria-label="로직크래프트 홈">
      <img src="/logo-mark.png" alt="" />
      <b>로직크래프트</b>
    </a>
    <nav class="nav-links" aria-label="주요 메뉴">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : undefined}>{l.label}</a>
      ))}
      <a href={cta.href} class="nav-cta">{cta.label}</a>
    </nav>
    <button class="menu-btn" id="menuBtn" aria-label="메뉴 열기" aria-expanded="false"><span></span></button>
  </div>
</header>

<nav class="mobile-menu" id="mobileMenu" aria-label="모바일 메뉴">
  {links.map((l) => (
    <a href={l.href}>{l.label} <span>{l.meta}</span></a>
  ))}
</nav>
